                #tankModal .bcum-body .glass-input:focus {
                    border-color: rgba(225,6,0,0.5);
                    box-shadow: 0 0 0 2px rgba(225,6,0,0.15);
                }

            #tankModal .bcum-body .select-trigger {
                height: 38px;
                padding: 0 12px;
                border-radius: 8px;
                border: 1px solid rgba(255,255,255,0.1);
                background: rgba(255,255,255,0.04);
                color: #fff;
                font-size: 13px;
                box-sizing: border-box;
                display: flex;
                align-items: center;
                justify-content: space-between;
                cursor: pointer;
                width: 100%;
            }

                #tankModal .bcum-body .select-trigger .arrow {
                    width: 0;
                    height: 0;
                    border-left: 4px solid transparent;
                    border-right: 4px solid transparent;
                    border-top: 5px solid rgba(255,255,255,0.35);
