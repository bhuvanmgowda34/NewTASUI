                }

            #tankModal .bcum-body .custom-select {
                position: relative;
            }

                #tankModal .bcum-body .custom-select.open {
                    z-index: 10000;
                }

            #tankModal .bcum-body .select-dropdown {
                position: absolute;
                top: calc(100% + 4px);
                left: 0;
                width: 100%;
                max-height: 180px;
                overflow-x: hidden;
