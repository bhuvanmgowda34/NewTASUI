@{
    ViewBag.Title = "Tanks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bay-module-card">

    <div class="bay-content">

        <div class="bay-form bcu-form tank-form">

        <!-- ROW 1 -->
        <div class="form-row four">
            <div class="form-group">
                <label>Tank No<span class="req">*</span></label>
                <input type="number" id="tankNo" class="glass-input" />
            </div>
            <div class="form-group">
                <label>Tank Name<span class="req">*</span></label>
                <input type="text" id="tankName" class="glass-input" maxlength="50" />
            </div>
            <div class="form-group">
                <label>SAP Tank No</label>
                <input type="text" id="sapTankNo" class="glass-input" maxlength="50" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <input type="text" id="tankDesc" class="glass-input" maxlength="50" />
            </div>
        </div>

        <!-- ROW 2 -->
        <div class="form-row four">
            <div class="form-group">
                <label>Product</label>
                <div class="custom-select" id="productSelect">
                    <div class="select-trigger"><span>Select Product</span><div class="arrow"></div></div>
                    <div class="select-dropdown" id="productDropdown"></div>
                </div>
            </div>
            <div class="form-group">
                <label>Tank Type</label>
                <div class="custom-select" id="tankTypeSelect">
                    <div class="select-trigger"><span>Select Tank Type</span><div class="arrow"></div></div>
                    <div class="select-dropdown" id="tankTypeDropdown"></div>
                </div>
            </div>
            <div class="form-group">
                <label>Tank Mode</label>
                <div class="custom-select" id="tankModeSelect">
                    <div class="select-trigger"><span>Select Tank Mode</span><div class="arrow"></div></div>
                    <div class="select-dropdown" id="tankModeDropdown"></div>
                </div>
            </div>
            <div class="form-group">
                <label>Gauge Type</label>
                <div class="custom-select" id="gaugeTypeSelect">
                    <div class="select-trigger"><span>Select Gauge Type</span><div class="arrow"></div></div>
                    <div class="select-dropdown" id="gaugeTypeDropdown"></div>
                </div>
            </div>
        </div>

        <!-- ROW 3 -->
        <div class="form-row four">
            <div class="form-group">
                <label>Capacity</label>
                <input type="number" id="tankCapacity" class="glass-input" step="0.001" />
            </div>
            <div class="form-group">
                <label>Min Level</label>
                <input type="number" id="minLevel" class="glass-input" step="0.001" />
            </div>
            <div class="form-group">
                <label>Max Level</label>
                <input type="number" id="maxLevel" class="glass-input" step="0.001" />
            </div>
            <div class="form-group">
                <label>Safe Height Level</label>
                <input type="number" id="safeHeightLevel" class="glass-input" step="0.001" />
            </div>
        </div>

        <!-- BOTTOM: checks + actions -->
        <div class="bcu-bottom">
            <div class="bcu-checks">
                <label class="bcu-checkbox">
                    <input type="checkbox" id="tankIsActive" />
                    <span class="bcu-checkmark"></span>
                    Is Active
                </label>
            </div>
            <div class="form-actions">
                <button class="btn-primary" onclick="saveTank()">Save</button>
                <button class="btn-secondary" onclick="clearTankForm()">Clear</button>
                <button class="btn-danger" onclick="deleteTank()">Delete</button>
            </div>
        </div>

    </div><!-- /.tank-form -->
    <!-- ═══════════════════════════════════════════
         TABLE SECTION
    ═══════════════════════════════════════════ -->
    <div class="bay-table tank-table">
        <div class="table-header">
            <div>Tank No</div>
            <div>Tank Name</div>
            <div>SAP Tank No</div>
            <div>Product</div>
            <div>Description</div>
            <div>Tank Type</div>
            <div>Tank Mode</div>
            <div>Gauge Type</div>
            <div>Capacity</div>
            <div>Min Level</div>
            <div>Max Level</div>
            <div>Safe Height</div>
            <div>Active</div>
        </div>
        <div class="table-body" id="tankTableBody">
            <div class="table-empty" id="tankTableEmpty">Loading...</div>
        </div>
    </div>
    </div><!-- /.bay-content -->
</div><!-- /.bay-module-card -->
<!-- ═══════════════════════════════════════════
     EDIT MODAL
═══════════════════════════════════════════ -->
    <div class="bcum-backdrop" id="tankBackdrop" onclick="closeTankModal()"></div>
    <div class="bcum-modal" id="tankModal">
        <div class="bcum-header">
            <div class="bcum-title">
                <span class="bcum-icon">&#9998;</span> Edit Tank
            </div>
            <button class="bcum-close" onclick="closeTankModal()">&#10005;</button>
        </div>
        <div class="bcum-body">
            <input type="hidden" id="editTankId" />

            <!-- ROW 1 -->
            <div class="form-row">
                <div class="form-group">
                    <label>Tank No</label>
                    <input type="number" id="editTankNo" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>Tank Name</label>
                    <input type="text" id="editTankName" class="glass-input" readonly style="opacity:0.55;cursor:default;" />
                </div>
                <div class="form-group">
                    <label>SAP Tank No</label>
                    <input type="text" id="editSapTankNo" class="glass-input" maxlength="50" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" id="editTankDesc" class="glass-input" maxlength="50" />
                </div>
            </div>

            <!-- ROW 2 -->
            <div class="form-row">
                <div class="form-group">
                    <label>Product</label>
                    <div class="custom-select" id="editProductSelect">
                        <div class="select-trigger"><span>Select Product</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editProductDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Tank Type</label>
                    <div class="custom-select" id="editTankTypeSelect">
                        <div class="select-trigger"><span>Select Tank Type</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editTankTypeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Tank Mode</label>
                    <div class="custom-select" id="editTankModeSelect">
                        <div class="select-trigger"><span>Select Tank Mode</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editTankModeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Gauge Type</label>
                    <div class="custom-select" id="editGaugeTypeSelect">
                        <div class="select-trigger"><span>Select Gauge Type</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editGaugeTypeDropdown"></div>
                    </div>
                </div>
            </div>

            <!-- ROW 3 -->
            <div class="form-row">
                <div class="form-group">
                    <label>Capacity</label>
                    <input type="number" id="editCapacity" class="glass-input" step="0.001" />
                </div>
                <div class="form-group">
                    <label>Min Level</label>
                    <input type="number" id="editMinLevel" class="glass-input" step="0.001" />
                </div>
                <div class="form-group">
                    <label>Max Level</label>
                    <input type="number" id="editMaxLevel" class="glass-input" step="0.001" />
                </div>
                <div class="form-group">
                    <label>Safe Height Level</label>
                    <input type="number" id="editSafeHeight" class="glass-input" step="0.001" />
                </div>
            </div>

            <!-- ROW 4: Is Active checkbox -->
            <div class="form-row tank-check-row">
                <div class="form-group" style="flex-direction:row;align-items:center;gap:20px;flex-wrap:wrap;">
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="editTankIsActive" />
                        <span class="bcu-checkmark"></span>
                        Is Active
                    </label>
                </div>
                <div class="form-group" style="flex:1;"></div>
                <div class="form-group" style="flex:1;"></div>
                <div class="form-group" style="flex:1;"></div>
            </div>

        </div><!-- /.bcum-body -->
        <div class="bcum-footer">
            <div style="flex:1;"></div>
            <button class="btn-secondary" onclick="closeTankModal()">Cancel</button>
            <button class="btn-primary" onclick="updateTankFromModal()">Update</button>
        </div>
    </div><!-- /#tankModal -->
<!-- ═══════════════════════════════════════════
     PAGE-SCOPED STYLES
═══════════════════════════════════════════ -->
<style>

    /* ── Tank form: matches BCU 4-col layout ── */
    .tank-form {
        width: 100%;
        overflow: visible !important;
    }

        .tank-form .form-row {
            display: flex;
            gap: 14px;
            margin-bottom: 1px;
            overflow: visible !important;
        }

            .tank-form .form-row.four {
                display: flex;
                gap: 14px;
            }

        .tank-form .form-group {
            flex: 1;
            min-width: 0;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: visible !important;
        }

            .tank-form .form-group > label:not(.bcu-checkbox) {
                font-size: 11px;
                color: rgba(255,255,255,0.7);
                margin-bottom: 5px;
                line-height: 1;
            }

        .tank-form .glass-input,
        .tank-form .select-trigger {
            height: 38px;
            width: 100%;
            padding: 0 12px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(255,255,255,0.04);
            color: #fff;
            font-size: 13px;
            box-sizing: border-box;
            outline: none;
        }

            .tank-form .glass-input:focus {
                border-color: rgba(225,6,0,0.5);
                box-shadow: 0 0 0 2px rgba(225,6,0,0.12);
            }

        .tank-form .select-trigger {
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
        }

        /* ── Custom select ── */
        .tank-form .custom-select {
            position: relative;
            width: 100%;
        }

            .tank-form .custom-select.open {
                z-index: 99999;
            }

        .tank-form .select-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            width: 100%;
            max-height: 220px;
            overflow-x: hidden;
            overflow-y: auto;
            scrollbar-gutter: stable;
            background: rgba(20,20,20,0.98);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            z-index: 99999;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
            box-sizing: border-box;
        }

        .tank-form .custom-select.open .select-dropdown {
            display: block;
        }

        .tank-form,
        .tank-form .form-row,
        .tank-form .form-group,
        .bay-module-card,
        .bay-content {
            overflow: visible !important;
        }

    /* ── Bottom row ── */
    .bcu-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 6px;
    }

    /* Buttons spacing */
    .action-buttons,
    .form-actions,
    .form-footer {
        margin-top: -4px !important;
        margin-bottom: -4px !important;
    }
    /* ── Arrow ── */
    .tank-form .select-trigger .arrow {
        width: 0;
        height: 0;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 5px solid rgba(255,255,255,0.35);
        flex-shrink: 0;
    }

    /* ── Dropdown options ── */
    .tank-form .select-dropdown .option {
        padding: 8px 12px;
        font-size: 12px;
        color: rgba(255,255,255,0.85);
        cursor: pointer;
        transition: background 0.1s;
    }

        .tank-form .select-dropdown .option:hover {
            background: rgba(255,255,255,0.08);
        }

    /* ── Table: 13 cols ── */
    .tank-table .table-header,
    .tank-table .table-row {
        grid-template-columns: 70px 1.2fr 1fr 1.2fr 1.2fr 1fr 1fr 1fr 0.8fr 0.8fr 0.8fr 1fr 0.7fr;
        font-size: 11px;
    }

    .tank-table {
        flex: 1;
        min-height: 0;
    }

        .tank-table .table-row {
            cursor: pointer;
        }

            .tank-table .table-row:hover {
                background: rgba(255,255,255,0.04);
            }

            .tank-table .table-row.tank-selected {
                background: rgba(225,6,0,0.07) !important;
                border-left: 2px solid #e10600;
            }

    /* ═══════════════════════════════════════════
           TANK MODAL — mirrors BCU modal exactly
        ═══════════════════════════════════════════ */
    #tankModal {
        width: min(860px, 94%) !important;
    }

        #tankModal .bcum-body {
            padding: 20px 20px 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

            #tankModal .bcum-body .form-row {
                display: flex;
                gap: 16px;
