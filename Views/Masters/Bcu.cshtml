@{
    ViewBag.Title = "Bcu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="bay-module-card">

    <!-- TABS -->
    <div class="bay-toggle">
        <div class="bay-tab active" id="tabBCU">BCUs</div>
        <div class="bay-tab" id="tabBCUProd">BCU Products</div>
        <div class="bay-indicator"></div>
    </div>

    <!-- ═══════════════════════════════════════════
         BCU TAB
    ════════════════════════════════════════════════ -->
    <div class="bay-content bcu-tab-content" id="bcuTab">

        <!-- FORM -->
        <div class="bay-form bcu-form">

            <!-- ROW 1 -->
            <div class="form-row four">
                <div class="form-group">
                    <label>BCU Name<span class="req">*</span></label>
                    <input type="text" id="bcuName" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>BCU Number<span class="req">*</span></label>
                    <input type="number" id="bcuNumber" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>BCU Type</label>
                    <div class="custom-select" id="bcuTypeSelect">
                        <div class="select-trigger"><span>Select Type</span></div>
                        <div class="select-dropdown" id="bcuTypeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Bay</label>
                    <div class="custom-select" id="bcuBaySelect">
                        <div class="select-trigger"><span>Select Bay</span></div>
                        <div class="select-dropdown" id="bcuBayDropdown"></div>
                    </div>
                </div>
            </div>

            <!-- ROW 2 -->
            <div class="form-row four">
                <div class="form-group">
                    <label>Slave Address<span class="req">*</span></label>
                    <input type="number" id="bcuSlaveAddr" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>Secondary Slave Address</label>
                    <input type="number" id="bcuRedSlaveAddr" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>Primary COM Port<span class="req">*</span></label>
                    <div class="custom-select" id="bcuComPortSelect">
                        <div class="select-trigger"><span>Select Port</span></div>
                        <div class="select-dropdown" id="bcuComPortDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Secondary COM Port</label>
                    <div class="custom-select" id="bcuRedComPortSelect">
                        <div class="select-trigger"><span>Select Port</span></div>
                        <div class="select-dropdown" id="bcuRedComPortDropdown"></div>
                    </div>
                </div>
            </div>

            <!-- ROW 3 -->
            <div class="form-row four">
                <div class="form-group">
                    <label>Arm No</label>
                    <input type="number" id="bcuArmNo" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>Arm Type</label>
                    <div class="custom-select" id="bcuArmTypeSelect">
                        <div class="select-trigger"><span>Select Arm Type</span></div>
                        <div class="select-dropdown" id="bcuArmTypeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Blend Mode</label>
                    <div class="custom-select" id="BlendModeSelect">
                        <div class="select-trigger"><span>Select Blend Mode</span></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Meter Type</label>
                    <div class="custom-select" id="MeterTypeSelect">
                        <div class="select-trigger"><span>Select Meter Type</span></div>
                    </div>
                </div>
            </div>

            <div class="bcu-bottom">
                <!-- LEFT SIDE -->
                <div class="bcu-checks">
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="bcuIsCardReader" />
                        <span class="bcu-checkmark"></span>
                        Is Cardreader Integrated
                    </label>
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="bcuIsActive" />
                        <span class="bcu-checkmark"></span>
                        Is Active
                    </label>
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="bcuMFMStatus" />
                        <span class="bcu-checkmark"></span>
                        MFM Status
                    </label>
                </div>
                <!-- RIGHT SIDE -->
                <div class="form-actions">
                    <button class="btn-primary" onclick="saveBCU()">Save</button>
                    <button class="btn-secondary" onclick="clearBCUForm()">Clear</button>
                    <button class="btn-danger" onclick="deleteBCU()">Delete</button>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="bay-table bcu-table">
            <div class="table-header">
                <div>BCU Name</div>
                <div>BCU No</div>
                <div>Bay Name</div>
                <div>BCU Type</div>
                <div>Pri. ComPort</div>
                <div>Pri. Addr</div>
                <div>Sec. ComPort</div>
                <div>Sec. Addr</div>
                <div>Card Reader</div>
                <div>Active</div>
                <div>Arm Type</div>
                <div>Arm No</div>
                <div>MFM</div>
            </div>
            <div class="table-body" id="bcuTableBody">
                <div class="table-empty" id="bcuTableEmpty">Loading...</div>
            </div>
        </div>

    </div><!-- /#bcuTab -->
    <!-- ═══════════════════════════════════════════
         BCU PRODUCTS TAB
    ════════════════════════════════════════════════ -->
    <div class="bay-content bcu-tab-content hidden" id="bcuProdTab">

        <!-- BCU selector -->
        <div class="bcu-prod-top">
            <div class="form-group bcu-prod-selector">
                <label>BCU</label>
                <div class="custom-select" id="prodBcuSelect">
                    <div class="select-trigger"><span>Select BCU</span><div class="arrow"></div></div>
                    <div class="select-dropdown" id="prodBcuDropdown"></div>
                </div>
            </div>
        </div>

        <!-- Dual list + transfer buttons -->
        <div class="bcu-prod-body">

            <!-- Available products list -->
            <div class="material-box">
                <div class="box-title">List of Available Products</div>
                <div class="material-list" id="availableProducts">
                    <div style="color:rgba(255,255,255,0.25);font-size:12px;padding:12px">Select a BCU to load products</div>
                </div>
            </div>

            <!-- Transfer buttons -->
            <div class="material-controls">
                <button class="transfer-btn" onclick="addProduct()">&gt;</button>
                <button class="transfer-btn" onclick="removeProduct()">&lt;</button>
            </div>

            <!-- Associated products list -->
            <div class="material-box">
                <div class="box-title">List of BCU Associated Products</div>
                <div class="material-list" id="associatedProducts">
                    <div style="color:rgba(255,255,255,0.25);font-size:12px;padding:12px">Select a BCU to load products</div>
                </div>
            </div>

        </div>

        <!-- BCU Products detail table -->
        <div class="bay-table bcu-prod-table">
            <div class="table-header">
                <div>Product Name</div>
                <div>Is Additive</div>
                <div>Arm No</div>
                <div>Recipe Number</div>
            </div>
            <div class="table-body" id="bcuProdTableBody">
                <div class="table-empty" id="bcuProdTableEmpty">Select a BCU to view products.</div>
            </div>
        </div>

        <!-- Inline editor — kept in DOM, always hidden (replaced by modal) -->
        <div class="bcu-prod-editor hidden" id="bcuProdEditor">
            <div class="bcu-prod-editor-inner">
                <input type="hidden" id="editBCUProductId" />
                <label class="bcu-checkbox">
                    <input type="checkbox" id="editIsAdditive" />
                    <span class="bcu-checkmark"></span>
                    Is Additive
                </label>
                <div class="form-group" style="flex-direction:row;align-items:center;gap:8px">
                    <label style="white-space:nowrap;font-size:11px;color:rgba(255,255,255,0.65)">Recipe Number</label>
                    <input type="number" id="editRecipeNo" placeholder="Recipe No" min="0"
                           class="glass-input" style="width:100px;height:30px" />
                </div>
                <div class="form-group" style="flex-direction:row;align-items:center;gap:8px">
                    <label style="white-space:nowrap;font-size:11px;color:rgba(255,255,255,0.65)">Arm No</label>
                    <input type="number" id="editArmNo" placeholder="Arm No" min="0"
                           class="glass-input" style="width:80px;height:30px" />
                </div>
                <button class="btn-primary" onclick="updateBCUProduct()">Update</button>
                <button class="btn-secondary" onclick="closeProductEditor()">Cancel</button>
            </div>
        </div>

    </div><!-- /#bcuProdTab -->
    <!-- ===== BCU EDITOR MODAL ===== -->
    <div class="bcum-backdrop" id="bcumBackdrop" onclick="closeBCUEditor()"></div>
    <div class="bcum-modal" id="bcumModal">
        <div class="bcum-header">
            <div class="bcum-title">
                <span class="bcum-icon">✎</span> Edit BCU
            </div>
            <button class="bcum-close" onclick="closeBCUEditor()">✕</button>
        </div>
        <div class="bcum-body">
            <input type="hidden" id="editBCUId" />
            <div class="form-row">
                <div class="form-group">
                    <label>BCU Name</label>
                    <input type="text" id="editBCUName" class="glass-input"
                           readonly style="opacity:0.55;cursor:default;" />
                </div>
                <div class="form-group">
                    <label>BCU Number</label>
                    <input type="number" id="editBCUNumber" class="glass-input" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>BCU Type</label>
                    <div class="custom-select" id="editBCUTypeSelect">
                        <div class="select-trigger"><span>Select Type</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editBCUTypeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Bay</label>
                    <div class="custom-select" id="editBCUBaySelect">
                        <div class="select-trigger"><span>Select Bay</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editBCUBayDropdown"></div>
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Slave Address</label>
                    <input type="number" id="editSlaveAddr" class="glass-input" />
                </div>
                <div class="form-group">
                    <label>Secondary Slave Address</label>
                    <input type="number" id="editRedSlaveAddr" class="glass-input" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Primary COM Port</label>
                    <div class="custom-select" id="editBCUComPortSelect">
                        <div class="select-trigger"><span>Select Port</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editBCUComPortDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Secondary COM Port</label>
                    <div class="custom-select" id="editBCURedComPortSelect">
                        <div class="select-trigger"><span>Select Port</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editBCURedComPortDropdown"></div>
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Arm Type</label>
                    <div class="custom-select" id="editBCUArmTypeSelect">
                        <div class="select-trigger"><span>Select Arm Type</span><div class="arrow"></div></div>
                        <div class="select-dropdown" id="editBCUArmTypeDropdown"></div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Arm No</label>
                    <input type="number" id="editBCUArmNo" class="glass-input" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex-direction:row;align-items:center;gap:20px;flex-wrap:wrap;">
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="editBCUCardReader" />
                        <span class="bcu-checkmark"></span>
                        Card Reader
                    </label>
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="editBCUMFMStatus" />
                        <span class="bcu-checkmark"></span>
                        MFM Status
                    </label>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <div class="bcum-status-toggle" id="bcumStatusToggle" onclick="toggleBCUStatus()">
                        <div class="bcum-dot" id="bcumStatusDot"></div>
                        <span id="bcumStatusLabel">Active</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="bcum-footer">
            <div style="flex:1"></div>
            <button class="btn-secondary" onclick="closeBCUEditor()">Cancel</button>
            <button class="btn-primary" onclick="updateBCUFromModal()">Update</button>
        </div>
    </div>

    <!-- ===== BCU PRODUCT EDITOR MODAL ===== -->
    <div class="bcum-backdrop" id="bcupBackdrop" onclick="closeProdModal()"></div>
    <div class="bcum-modal" id="bcupModal">
        <div class="bcum-header">
            <div class="bcum-title">
                <span class="bcum-icon">✎</span> Edit BCU Product
            </div>
            <button class="bcum-close" onclick="closeProdModal()">✕</button>
        </div>
        <div class="bcum-body">
            <input type="hidden" id="modalBCUProductId" />
            <!-- ROW 1: Product Name (full width) -->
            <div class="form-row">
                <div class="form-group" style="flex:1;">
                    <label>Product Name</label>
                    <input type="text" id="modalProductName" class="glass-input"
                           readonly style="opacity:0.55;cursor:default;" />
                </div>
            </div>
            <!-- ROW 2: Recipe Number + Arm No -->
            <div class="form-row">
                <div class="form-group">
                    <label>Recipe Number</label>
                    <input type="number" id="modalRecipeNo" class="glass-input" min="0" />
                </div>
                <div class="form-group">
                    <label>Arm No</label>
                    <input type="number" id="modalArmNo" class="glass-input" min="0" />
                </div>
            </div>
            <!-- ROW 3: Is Additive checkbox -->
            <div class="form-row bcup-check-row">
                <div class="form-group">
                    <label class="bcu-checkbox">
                        <input type="checkbox" id="modalIsAdditive" />
                        <span class="bcu-checkmark"></span>
                        Is Additive
                    </label>
                </div>
            </div>
        </div>
        <div class="bcum-footer">
            <div style="flex:1"></div>
            <button class="btn-secondary" onclick="closeProdModal()">Cancel</button>
            <button class="btn-primary" onclick="submitProdModal()">Update</button>
        </div>
    </div>

</div><!-- /.bay-module-card -->


<style>
    /* ===== BCU FORM FIXED GRID ===== */
    .bcu-form {
        width: 100%;
        margin: auto;
        overflow: visible !important;
    }

        .bcu-form .form-row + .form-row {
            margin-top: 1px;
        }

        .bcu-form .form-row {
            display: flex;
            gap: 14px;
        }

        .bcu-form .form-group {
            flex: 1;
            min-width: 0;
            position: relative;
        }

        .bcu-form .custom-select {
            position: relative;
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
        }

            .bcu-form .custom-select.open {
                z-index: 99999;
                position: relative;
            }

        .bcu-form .select-dropdown {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            width: 100%;
            max-height: 220px;
            overflow-x: hidden;
            overflow-y: auto;
            scrollbar-gutter: stable;
            background: rgba(20,20,20,0.98);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            z-index: 99999;
            display: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
            box-sizing: border-box;
        }

        .bcu-form .custom-select.open .select-dropdown {
            display: block;
        }

        .bcu-form,
        .bcu-form .form-row,
        .bay-content,
        .bay-module-card {
            overflow: visible !important;
        }

            .bcu-form .form-group label {
                font-size: 11px;
                color: rgba(255,255,255,0.7);
                margin-bottom: 5px;
            }

            .bcu-form .glass-input,
            .bcu-form .select-trigger {
                height: 38px;
                width: 100%;
                padding: 8px 12px;
                border-radius: 8px;
                border: 1px solid rgba(255,255,255,0.12);
                background: rgba(255,255,255,0.04);
                color: #fff;
                font-size: 13px;
                box-sizing: border-box;
            }

            .bcu-form .select-trigger {
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

    .form-row {
        align-items: start;
    }

    /* ===== LAST SECTION ===== */
    .bcu-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: -10px;
    }

    .bcu-checks {
        display: flex;
        gap: 18px;
        align-items: center;
    }

    .form-actions {
        display: flex;
        gap: 10px;
    }

    /* ===== DROPDOWN ===== */
    .custom-select {
        position: relative;
        width: 100%;
    }

    /* Default hidden state for ALL dropdowns not inside .bcu-form */
    .select-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        width: 100%;
        max-height: 220px;
        overflow-x: hidden;
        overflow-y: auto;
        scrollbar-gutter: stable;
        background: rgba(20,20,20,0.98);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        z-index: 99999;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    }

    .custom-select.open .select-dropdown {
        display: block;
    }

    /* BCU Products top area must not clip the dropdown */
    #bcuProdTab,
    .bcu-prod-top {
        overflow: visible !important;
    }

    /* ===== BCU TABLE ===== */
    .bcu-table {
        flex: 1;
        min-height: 0;
        margin-top: -10px;
    }

    .req {
        color: #e10600;
        margin-left: 2px;
        font-size: 10px;
    }

    /* ── BCU Checks ── */
    .bcu-checkbox {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        font-size: 12px;
        color: rgba(255,255,255,0.72);
        user-select: none;
        white-space: nowrap;
    }

        .bcu-checkbox input[type="checkbox"] {
            display: none;
        }

    .bcu-checkmark {
        width: 15px;
        height: 15px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.22);
        background: rgba(255,255,255,0.04);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, border-color 0.15s;
        flex-shrink: 0;
    }

    .bcu-checkbox input:checked + .bcu-checkmark {
        background: #e10600;
        border-color: #e10600;
    }

    .bcu-checkmark::after {
        content: "✓";
        font-size: 9px;
        color: #fff;
        font-weight: 700;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .bcu-checkbox input:checked + .bcu-checkmark::after {
        opacity: 1;
    }

    /* ── BCU table: 13 cols ── */
    .bcu-table .table-header,
    .bcu-table .table-row {
        grid-template-columns: 1fr 60px 90px 1fr 90px 70px 90px 70px 80px 65px 90px 60px 60px;
        font-size: 11px;
    }

    /* ── BCU Products tab ── */
    .bcu-prod-top {
        margin-bottom: 1px;
        display: flex;
        gap: 14px;
    }

    .bcu-prod-top .bcu-prod-selector {
        flex: 0 0 calc((100% - 42px) / 4);
        max-width: calc((100% - 42px) / 4);
        min-width: 0;
    }

    #prodBcuSelect {
        width: 100%;
        box-sizing: border-box;
    }

    #prodBcuSelect .select-trigger {
        width: 100%;
        height: 38px;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: #fff;
        font-size: 13px;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    #prodBcuSelect .select-dropdown {
        width: 100%;
        box-sizing: border-box;
    }

    /* Constrained dual-list row */
    .bcu-prod-body {
        display: grid;
        grid-template-columns: 1fr 60px 1fr;
        gap: 16px;
        margin-bottom: 26px;
        flex-shrink: 0;
        /* FIX: prevent expansion */
        height: 200px;
        min-height: 200px;
        max-height: 200px;
    }

    /* Each panel */
    .material-box {
        height: 200px;
        min-height: 200px;
        max-height: 200px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* Scrollable list inside panel */
    .material-list {
        flex: 1;
        overflow-y: auto;
        /* IMPORTANT: prevents stretch */
        min-height: 0;
    }

    .bcu-prod-table .table-header,
    .bcu-prod-table .table-row {
        grid-template-columns: 1fr 100px 80px 120px;
    }

    /* Inline product editor (kept hidden — modal replaces it) */
    .bcu-prod-editor {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 12px;
        margin-top: 8px;
        flex-shrink: 0;
    }

    .bcu-prod-editor-inner {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    /* ── Row states ── */
    .table-row {
        cursor: pointer;
    }

        .table-row:hover {
            background: rgba(255,255,255,0.04);
        }

        .table-row.bcu-selected {
            background: rgba(225,6,0,0.07) !important;
            border-left: 2px solid #e10600;
        }

    .table-empty {
        padding: 28px;
        text-align: center;
        color: rgba(255,255,255,0.28);
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    /* bool cells */
    .bcu-bool-yes {
        color: #00ff9c;
        font-size: 13px;
        text-shadow: 0 0 5px rgba(0,255,150,0.4);
    }

    .bcu-bool-no {
        color: rgba(255,255,255,0.18);
        font-size: 13px;
    }

    /* product item in list */
    .prod-item {
        padding: 6px 10px;
        font-size: 12px;
        color: rgba(255,255,255,0.85);
        border-radius: 6px;
        cursor: pointer;
    }

        .prod-item:hover {
            background: rgba(255,255,255,0.08);
        }

        .prod-item.prod-selected {
            background: rgba(225,6,0,0.12);
            border: 1px solid rgba(225,6,0,0.35);
        }

    .btn-danger {
        padding: 8px 14px;
        border-radius: 999px;
        border: 1px solid rgba(225,6,0,0.38);
        background: rgba(225,6,0,0.09);
        color: #ff5555;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        box-shadow: 0 3px 8px rgba(0,0,0,0.3);
        transition: background 0.15s, border-color 0.15s;
        position: relative;
        z-index: 3;
    }

        .btn-danger:hover {
            background: rgba(225,6,0,0.2);
            border-color: #e10600;
        }

        .btn-danger:active {
            transform: scale(0.95);
        }

    /* ── BCU Editor Modal ── */
    .bcum-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: 1000;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

        .bcum-backdrop.show {
            opacity: 1;
        }

    .bcum-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -48%) scale(0.95);
        width: min(600px, 90%);
        background: linear-gradient(160deg, rgba(42,42,42,0.99) 0%, rgba(22,22,22,0.97) 100%);
        border: 1px solid rgba(255,255,255,0.13);
        border-radius: 14px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.1);
        z-index: 1001;
