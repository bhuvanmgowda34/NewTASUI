<!-- ???????????????????????????????????????????
     JAVASCRIPT
??????????????????????????????????????????? -->
<script>

    /* ???????????????????????????????????????
       STATE
    ??????????????????????????????????????? */
    var selectedTruckId   = null;
    var selectedTruckNum  = null;
    var selectedReason    = null;
    var availTrucksList   = [];
    var entryReasonList   = [];
    var selectedEntryId = null;
    var todayTrucksList = [];

        /* ???????????????????????????????????????
       BOOT
    ??????????????????????????????????????? */
    document.addEventListener("DOMContentLoaded", function () {
        loadAvailableTrucks();
        loadTodayTrucks();
        loadEntryReasons();
        wireReasonDropdown();
    });

    /* ???????????????????????????????????????
       DATA LOADS
    ??????????????????????????????????????? */
    function loadAvailableTrucks() {
        setEmpty("availTruckEmpty", "Loading...", true);
        fetch("/Truck/GetAvailableTrucks")
            .then(function(r) { return r.json(); })
            .then(function(data) {
                availTrucksList = Array.isArray(data) ? data : [];
                renderAvailTrucks(availTrucksList);
            })
            .catch(function() { setEmpty("availTruckEmpty", "Failed to load.", true); });
    }

    function loadTodayTrucks() {
        setEmpty("todayTruckEmpty", "Loading...", true);
        fetch("/Truck/GetTodayTrucks")
            .then(function(r) { return r.json(); })
            .then(function(data) {
     todayTrucksList = Array.isArray(data) ? data : [];
    renderTodayTrucks(todayTrucksList);
            })
            .catch(function() { setEmpty("todayTruckEmpty", "Failed to load.", true); });
    }

    function loadEntryReasons() {
        renderReasonDropdown(true);
        fetch("/Truck/GetEntryReasons")
            .then(function(r) { return r.json(); })
            .then(function(data) {
                entryReasonList = Array.isArray(data) ? data : [];
                renderReasonDropdown(false);
            })
            .catch(function() {
                entryReasonList = [];
                renderReasonDropdown(false);
            });
    }

        /* ???????????????????????????????????????
       RENDER — Available Trucks
    ??????????????????????????????????????? */
    function renderAvailTrucks(list) {
        var body  = document.getElementById("availTruckBody");
        var empty = document.getElementById("availTruckEmpty");
        if (!body) return;

        if (!list || !list.length) {
            body.innerHTML = "";
            setEmpty("availTruckEmpty", "No trucks available.", true);
            return;
        }
        if (empty) empty.style.display = "none";

        body.innerHTML = list.map(function(t) {
            var sel = (t.truckId === selectedTruckId) ? " te-selected" : "";
            return '<div class="table-row' + sel + '" data-id="' + t.truckId + '"' +
                   ' onclick="onAvailRowClick(' + t.truckId + ', \'' + escJs(t.registrationNumber) + '\')">' +
                   '<div class="te-row-check">' +
                       '<input type="radio" name="truckSel" ' + (t.truckId === selectedTruckId ? 'checked' : '') + ' />' +
                       '<div class="te-radio-mark"></div>' +
                   '</div>' +
                   '<div>' + esc(t.registrationNumber) + '</div>' +
                   '<div>' + esc(t.truckType)          + '</div>' +
                   '<div class="te-center">' + escVal(t.truckKey) + '</div>' +
                   '<div>' + esc(t.companyName)         + '</div>' +
                   '<div class="te-center">' + escVal(t.noOfCompartments) + '</div>' +
                   '<div class="' + (t.isPermanent ? 'te-status-y' : 'te-status-n') + '">' + (t.isPermanent ? '&#10004;' : '&mdash;') + '</div>' +
                   '<div>' + fmtDec(t.printedTareWeight)  + '</div>' +
                   '<div>' + fmtDec(t.printedGrossWeight) + '</div>' +
                   '<div>' + fmtDec(t.tankerTareWeight)   + '</div>' +
                   '<div>' + fmtDec(t.tankerGrossWeight)  + '</div>' +
                   '<div>' + fmtDec(t.ccoePermWeight)     + '</div>' +
                   '<div class="' + licClass(t.callibrationDueDate) + '">' + fmtDate(t.callibrationDueDate) + '</div>' +
                   '<div class="' + licClass(t.licenseExpireDate) + '">' + fmtDate(t.licenseExpireDate)   + '</div>' +
                   '<div class="' + licClass(t.explosiveExpiryDate) + '">' + fmtDate(t.explosiveExpiryDate) + '</div>' +
                   '<div class="te-action-cell">&mdash;</div>' +
                   '</div>';
        }).join("");
    }

    /* ???????????????????????????????????????
       RENDER — Today's Trucks
    ??????????????????????????????????????? */
    function renderTodayTrucks(list) {
        var body  = document.getElementById("todayTruckBody");
        var empty = document.getElementById("todayTruckEmpty");
        if (!body) return;

        if (!list || !list.length) {
            body.innerHTML = "";
            setEmpty("todayTruckEmpty", "No truck entries today.", true);
            return;
        }
        if (empty) empty.style.display = "none";

        body.innerHTML = list.map(function(t) {
            var statusHtml = (t.tTStatus === "Y" || t.ttStatus === "Y")
                ? '<span class="te-status-y">&#10004; Y</span>'
                : '<span class="te-status-n">&mdash; N</span>';

    var isSel = (t.truckEntryId === selectedEntryId) ? ' te-selected' : '';
    return '<div class="table-row' + isSel + '" data-eid="' + t.truckEntryId + '" onclick="onTodayRowClick(' + t.truckEntryId + ')">' +
                   '<div class="te-row-check"><div class="te-radio-mark"></div></div>' +
                   '<div>' + esc(t.entryDate)          + '</div>' +
                   '<div>' + esc(t.time)                + '</div>' +
                   '<div>' + esc(t.entryType)          + '</div>' +
                   '<div>' + esc(t.truckType)           + '</div>' +
                   '<div>' + esc(t.truckNumber)         + '</div>' +
                   '<div>' + esc(t.companyName)         + '</div>' +
                   '<div class="te-center">' + escVal(t.noOfCompartments) + '</div>' +
                   '<div class="te-center">' + escVal(t.truckKey) + '</div>' +
                   '<div class="' + (t.isPermanentKey ? 'te-status-y' : 'te-status-n') + '">' + (t.isPermanentKey ? '&#10004;' : '&mdash;') + '</div>' +
                   '<div>' + fmtDec(t.ccoePermWeight)   + '</div>' +
                   '<div>' + fmtDec(t.tankerTareWeight) + '</div>' +
                   '<div>' + fmtDec(t.tankerGrossWeight)+ '</div>' +
                   '<div class="' + licClass(t.callibrationDueDate) + '">' + fmtDate(t.callibrationDueDate) + '</div>' +
                   '<div class="' + licClass(t.licenseExpireDate) + '">' + fmtDate(t.licenseExpireDate) + '</div>' +
                   '<div>' + statusHtml + '</div>' +
                   '<div>' + escVal(t.sequenceNumber) + '</div>' +
                   '<div>' + esc(t.response || t.licenseExpiryInfo) + '</div>' +
                   '<div>' + esc(t.licenseExpiryInfo) + '</div>' +
                   '</div>';
        }).join("");
    }

    /* ???????????????????????????????????????
       ROW SELECTION
    ??????????????????????????????????????? */
    function onAvailRowClick(id, regNum) {
        if (selectedTruckId === id) {
            // Deselect
            selectedTruckId  = null;
            selectedTruckNum = null;
        } else {
            selectedTruckId  = id;
            selectedTruckNum = regNum;
        }
        renderAvailTrucks(getCurrentFilteredList());
    }
        function onTodayRowClick(id) {
        selectedEntryId = (selectedEntryId === id) ? null : id;
            renderTodayTrucks(todayTrucksList);
    }

    function getCurrentFilteredList() {
        var q = document.getElementById("truckSearch").value.trim().toLowerCase();
        if (!q) return availTrucksList;
        return availTrucksList.filter(function(t) {
            return t.registrationNumber && t.registrationNumber.toLowerCase().indexOf(q) !== -1;
        });
    }

    /* ???????????????????????????????????????
       SEARCH FILTER
    ??????????????????????????????????????? */
    function filterAvailableTable() {
        renderAvailTrucks(getCurrentFilteredList());
    }

    /* ???????????????????????????????????????
       ENTRY FLOW
    ??????????????????????????????????????? */

    // STEP 1: Entry button clicked
    function onEntryClick() {
        if (!selectedTruckId) {
            openModal("noSelModal", "noSelBackdrop");
            return;
        }
        // STEP 2: Show confirm modal
        document.getElementById("confirmTruckNum").textContent = selectedTruckNum || selectedTruckId;
        openModal("confirmModal", "confirmBackdrop");
    }

    // STEP 3: YES on confirm ? check SOD
    function onConfirmYes() {
        closeModal("confirmModal", "confirmBackdrop");

        // STEP 4: SOD check
        fetch("/Truck/CheckSOD")
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (!res.sodStarted) {
                    openModal("sodModal", "sodBackdrop");
                    return;
                }
                // STEP 5: Open manual entry form
                selectedReason = null;
                document.getElementById("reasonSelectLabel").textContent = "Select Reason";
                document.getElementById("reasonSelect").removeAttribute("data-val");
    if (!entryReasonList || entryReasonList.length === 0) {
        loadEntryReasons();
        setTimeout(() => {
            openModal("manualModal", "manualBackdrop");
        }, 200);
        return;
    }

    openModal("manualModal", "manualBackdrop");
                    openModal("manualModal", "manualBackdrop");
            })
            .catch(function() {
                showError("Failed to check TAS Day status. Please try again.");
            });
    }

    // STEP 6: POST
    function onPostEntry() {
        var reason = document.getElementById("reasonSelect").getAttribute("data-val");
        if (!reason) {
            showError("Please select a reason before posting.");
            return;
        }

        var btn   = document.getElementById("btnPost");
        var label = document.getElementById("btnPostLabel");
        btn.disabled    = true;
        label.textContent = "Posting...";

        fetch("/Truck/PostManualEntry", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ truckId: selectedTruckId, reason: reason })
        })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            btn.disabled      = false;
            label.textContent = "POST";

            if (res.success) {
                closeModal("manualModal", "manualBackdrop");
                selectedTruckId  = null;
                selectedTruckNum = null;
                selectedReason   = null;
                // Refresh both tables
                loadAvailableTrucks();
                loadTodayTrucks();
            } else if (res.message === "NO_SOD") {
                closeModal("manualModal", "manualBackdrop");
                openModal("sodModal", "sodBackdrop");
            } else {
                showError(res.message || "Entry failed. Please try again.");
            }
        })
        .catch(function() {
            btn.disabled      = false;
            label.textContent = "POST";
            showError("Network error. Please check your connection.");
        });
    }

    // SAP Posting — placeholder
    function onSapPosting() {
        showError("SAP Posting functionality is not yet implemented.");
    }

    /* ???????????????????????????????????????
       REASON DROPDOWN WIRING
    ??????????????????????????????????????? */
function wireReasonDropdown() {
    document.addEventListener("click", function(e) {
        var trigger = e.target.closest("#reasonSelect .select-trigger");
        if (trigger) {
            e.stopPropagation();
            var sel = document.getElementById("reasonSelect");
            var isOpen = sel.classList.contains("open");
            document.querySelectorAll(".te-modal-select.open").forEach(function(s) {
                s.classList.remove("open");
            });
            if (!isOpen) sel.classList.add("open");
            return;
        }
        if (!e.target.closest("#reasonSelect")) {
            var openSel = document.getElementById("reasonSelect");
            if (openSel) openSel.classList.remove("open");
        }
    });

    document.addEventListener("mousedown", function(e) {
        var opt = e.target.closest("#reasonDropdown .option");
        if (!opt) return;
        e.preventDefault();
        e.stopPropagation();
        if (opt.getAttribute("data-disabled") === "1") return;
        var sel = document.getElementById("reasonSelect");
        document.getElementById("reasonSelectLabel").textContent = opt.getAttribute("data-val");
        sel.setAttribute("data-val", opt.getAttribute("data-val"));
        sel.classList.remove("open");
    });
}


    function renderReasonDropdown(isLoading) {
        var dropdown = document.getElementById("reasonDropdown");
        if (!dropdown) return;

        if (isLoading) {
            dropdown.innerHTML = '<div class="option" data-disabled="1" data-val="">Loading...</div>';
            return;
        }

        if (!entryReasonList.length) {
            dropdown.innerHTML = '<div class="option" data-disabled="1" data-val="">No reasons found</div>';
            return;
        }

        dropdown.innerHTML = entryReasonList.map(function(r) {
            return '<div class="option" data-val="' + escAttr(r.reasonDescription) + '">' +
                esc(r.reasonDescription) +
                '</div>';
        }).join("");
    }


        /* ???????????????????????????????????????
       MODAL HELPERS
    ??????????????????????????????????????? */
    function openModal(modalId, backdropId) {
        var m = document.getElementById(modalId);
        var b = document.getElementById(backdropId);
        if (!m || !b) return;
        m.style.display = "block";
        b.style.display = "block";
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                m.classList.add("show");
                b.classList.add("show");
            });
        });
    }

    function closeModal(modalId, backdropId) {
        var m = document.getElementById(modalId);
        var b = document.getElementById(backdropId);
        if (!m || !b) return;
        m.classList.remove("show");
        b.classList.remove("show");
        setTimeout(function() {
            m.style.display = "none";
            b.style.display = "none";
        }, 220);
    }

    function showError(msg) {
        document.getElementById("errModalText").textContent = msg;
        openModal("errModal", "errBackdrop");
    }

    /* ???????????????????????????????????????
       HELPERS — formatting
    ??????????????????????????????????????? */
    function fmtDec(v) {
        if (v == null) return "<span style='color:rgba(255,255,255,0.18)'>&mdash;</span>";
        return parseFloat(v).toFixed(2);
    }

    function fmtDate(v) {
        if (!v) return "<span style='color:rgba(255,255,255,0.18)'>&mdash;</span>";
        var d = new Date(v);
        if (isNaN(d)) return v;
        var dd = ("0" + d.getDate()).slice(-2);
        var mm = ("0" + (d.getMonth() + 1)).slice(-2);
        var yy = d.getFullYear();
        return dd + "/" + mm + "/" + yy;
    }

    function licClass(v) {
        if (!v) return "";
        var d    = new Date(v);
        var now  = new Date();
        var diff = (d - now) / (1000 * 60 * 60 * 24);   // days
        if (diff < 0)   return "te-lic-exp";
        if (diff < 30)  return "te-lic-warn";
        return "te-lic-ok";
    }

    function setEmpty(id, msg, show) {
        var el = document.getElementById(id);
        if (!el) return;
        el.textContent  = msg;
        el.style.display = show ? "block" : "none";
    }

    function esc(s) {
        if (s == null) return "";
        return String(s)
            .replace(/&/g,  "&amp;")
            .replace(/</g,  "&lt;")
            .replace(/>/g,  "&gt;")
            .replace(/"/g,  "&quot;");
    }

    function escJs(s) {
        if (s == null) return "";
        return String(s).replace(/\\/g,"\\\\").replace(/'/g,"\\'");
    }

    function escVal(v) {
        if (v == null || v === "") return "&mdash;";
        return esc(v);
    }

    function escAttr(s) {
        if (s == null) return "";
        return String(s)
            .replace(/&/g, "&amp;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

</script>

