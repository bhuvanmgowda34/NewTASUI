@{
    ViewData["Title"] = "SOD / EOD";
}

<div class="bay-module-card sod-card">
    <div class="sod-top-grid">
        <div class="sod-instruction-panel">
            <div class="sod-label">Start the Day by clicking on Start Button</div>
            <div class="sod-label">End the Day by clicking on End Button</div>
            <div class="sod-note">(Please make sure all the trucks are exited before making EOD)</div>
        </div>

        <div class="sod-action-panel">
            <div class="sod-btn-stack">
                <button id="btnStartDay" class="btn-primary sod-btn" onclick="startDay()">START THE DAY</button>
                <button id="btnEndDay" class="btn-secondary sod-btn" onclick="endDay()">END THE DAY</button>
            </div>
        </div>

        <div class="sod-status-panel">
            <div class="sod-server-time">
                Current Server Time
                <span id="serverTimeValue">--/--/---- --:--:--</span>
            </div>
            <div class="sod-expected">
                Already Expected EOD Time is :
                <span id="expectedEodTime">23:59</span>
            </div>
            <button class="btn-secondary sod-small-btn" onclick="loadSODEODStatus()">Update End Time</button>
        </div>
    </div>

    <div class="sod-current-grid">
        <div class="sod-current-box">
            <div class="box-title sod-current-title">Current Start of Day Date Time</div>
            <div class="sod-current-value" id="currentSodDateTime">--/--/---- --:--:--</div>
        </div>
        <div class="sod-current-box">
            <div class="box-title sod-current-title">Current End of Day Date Time</div>
            <div class="sod-current-value" id="currentEodDateTime">--/--/---- --:--:--</div>
        </div>
    </div>

    <div class="sod-workflow-gate" id="workflowGateStatus">Workflow status loading...</div>

    <div class="table-wrapper">
        <div class="bay-table sod-table">
            <div class="table-header">
                <div>Day/Month/Year</div>
                <div>SOD</div>
                <div>EOD</div>
            </div>
            <div class="table-body" id="sodHistoryBody">
                <div class="table-empty" id="sodHistoryEmpty">Loading...</div>
            </div>
        </div>
    </div>
</div>

<div class="bcum-backdrop" id="sodNoticeBackdrop"></div>
<div class="bcum-modal te-modal" id="sodNoticeModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon te-warn-icon">&#9888;</span> Notice</div>
        <button class="bcum-close" onclick="closeSodNoticeModal()">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text" id="sodNoticeText"></p>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-primary" onclick="closeSodNoticeModal()">OK</button>
    </div>
</div>

<style>
    .sod-card { gap: 10px; overflow: visible; }

    .sod-top-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 12px;
        align-items: start;
    }

    .sod-instruction-panel {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
    }

    .sod-action-panel {
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
        padding-top: 1px;
    }

    .sod-label {
        font-size: 13px;
        color: rgba(255,255,255,0.8);
        letter-spacing: 0.2px;
    }

    .sod-btn-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .sod-btn {
        height: 30px;
        min-width: 132px;
        font-size: 11px;
        letter-spacing: 0.6px;
        display: flex;
        gap: 10px;
        justify-content: center;
        align-items: center;
    }

    .sod-note {
        margin-top: -3px;
        color: rgba(255,255,255,0.7);
        font-size: 11px;
        font-style: italic;
    }

    .sod-status-panel {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
        min-width: 0;
    }

    .sod-server-time,
    .sod-expected {
        font-size: 13px;
        color: rgba(255,255,255,0.88);
        text-align: right;
    }

    #serverTimeValue, #expectedEodTime {
        color: #8fc2ff;
        font-weight: 600;
        margin-left: 8px;
    }

    .sod-small-btn {
        height: 30px;
        width: 138px;
        font-size: 11px;
        padding: 6px 10px;
    }

    .sod-current-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        margin-top: 0;
    }

    .sod-current-box {
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
        padding: 6px 10px;
        min-height: 46px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .sod-current-title {
        font-size: 11px;
        color: rgba(255,255,255,0.72);
        margin-bottom: 2px;
        letter-spacing: 0.4px;
        text-transform: uppercase;
    }

    .sod-current-value {
        font-size: 13px;
        color: #90f7a5;
        font-weight: 600;
    }

    .sod-workflow-gate {
        font-size: 12px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        padding: 5px 9px;
        min-height: 18px;
        color: rgba(255,255,255,0.9);
        text-align: center;
    }

    .sod-workflow-gate.ok {
        border-color: rgba(0,255,156,0.3);
        color: #00ff9c;
    }

    .sod-workflow-gate.blocked {
        border-color: rgba(225,6,0,0.4);
        color: #ff7f7f;
    }

    .sod-table { margin-top: 0; }

    .sod-table .table-header,
    .sod-table .table-row {
            display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        font-size: 12px;
    }

    .sod-table .table-row {
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .sod-table .table-row:hover {
        background: rgba(255,255,255,0.04);
    }

    .sod-table .table-row.sod-selected {
        background: rgba(225,6,0,0.07) !important;
        border-left: 2px solid #e10600;
    }

    .sod-table .table-header {
        font-size: 13px;
    }

    .table-wrapper {
        width: 100%;
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }

    .table-wrapper .sod-table {
        width: 100%;
        height: 100%;
        min-height: 0;
    }

    .table-wrapper .sod-table .table-body {
        max-height: none;
        min-height: 0;
        overflow-y: auto;
        overflow-x: auto;
        flex: 1;
    }

    .te-modal {
        width: min(440px, 92%) !important;
    }

    .te-modal-body {
        padding: 22px 22px 10px !important;
        gap: 14px !important;
    }

    .te-confirm-text {
        font-size: 13px;
        color: rgba(255,255,255,0.8);
        line-height: 1.6;
        margin: 0;
    }

    .te-warn-icon {
        color: #ffd600 !important;
    }

    .bcum-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: 1000;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

        .bcum-backdrop.show {
            opacity: 1;
        }

    .bcum-modal {
        display: none;
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -48%) scale(0.95);
        background: linear-gradient(160deg, rgba(42,42,42,0.99) 0%, rgba(22,22,22,0.97) 100%);
        border: 1px solid rgba(255,255,255,0.13);
        border-radius: 14px;
        box-shadow: 0 32px 80px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.1);
        z-index: 1001;
        opacity: 0;
        transition: opacity 0.22s ease, transform 0.22s cubic-bezier(.2,.8,.2,1);
    }

        .bcum-modal.show {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }

    .bcum-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px 13px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .bcum-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.9);
        letter-spacing: 0.4px;
    }

    .bcum-icon {
        color: #e10600;
        font-size: 15px;
    }

    .bcum-close {
        background: none;
        border: none;
        color: rgba(255,255,255,0.35);
        font-size: 15px;
        cursor: pointer;
        padding: 3px 7px;
        border-radius: 5px;
        transition: color 0.15s, background 0.15s;
        line-height: 1;
    }

        .bcum-close:hover {
            color: #e10600;
            background: rgba(225,6,0,0.1);
        }

    .bcum-body {
        padding: 20px 20px 16px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .bcum-footer {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 20px 18px;
        border-top: 1px solid rgba(255,255,255,0.07);
    }
</style>

<script>
    let serverTimeInterval = null;
    let sodRequestInFlight = false;
    let eodRequestInFlight = false;
    let selectedHistoryKey = null;
    let lastHistorySignature = "";

    document.addEventListener("DOMContentLoaded", function () {
        loadSODEODStatus();
        if (serverTimeInterval) clearInterval(serverTimeInterval);
        serverTimeInterval = setInterval(loadSODEODStatus, 1000);
    });

    function loadSODEODStatus() {
        fetch("/SODEOD/GetSODEODStatus")
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res && res.success === false) {
                    showSodNotice(res.message || "Failed to load SOD/EOD status.");
                    return;
                }

                var serverTime = pick(res, "serverTime");
                var expectedEodTime = pick(res, "expectedEODTime", "expectedEodTime");
                var currentSod = pick(res, "currentSODDateTime", "currentSodDateTime");
                var currentEod = pick(res, "currentEODDateTime", "currentEodDateTime");
                var canStart = !!pick(res, "canStartDay");
                var canEnd = !!pick(res, "canEndDay");
                var history = pick(res, "history") || [];

                document.getElementById("serverTimeValue").textContent = fmtDateTime(serverTime);
                document.getElementById("expectedEodTime").textContent = expectedEodTime || "23:59";
                document.getElementById("currentSodDateTime").textContent = currentSod ? fmtDateTime(currentSod) : "--/--/---- --:--:--";
                document.getElementById("currentEodDateTime").textContent = currentEod ? fmtDateTime(currentEod) : "--/--/---- --:--:--";

                var btnStart = document.getElementById("btnStartDay");
                var btnEnd = document.getElementById("btnEndDay");
                btnStart.disabled = !canStart;
                btnEnd.disabled = !canEnd;
                btnStart.style.opacity = canStart ? "1" : "0.55";
                btnEnd.style.opacity = canEnd ? "1" : "0.55";

                updateWorkflowGate(res);
                renderHistory(history);
            })
            .catch(function () {
                document.getElementById("sodHistoryEmpty").textContent = "Failed to load.";
            });
    }

    function updateWorkflowGate(res) {
        var gate = document.getElementById("workflowGateStatus");
        gate.classList.remove("ok", "blocked");

        var canProceed = !!pick(res, "canProceedForWorkflow");
        var isSodDone = !!pick(res, "isSODDone", "isSodDone");
        var isEodDone = !!pick(res, "isEODDone", "isEodDone");

        if (canProceed) {
            gate.classList.add("ok");
            gate.textContent = "The workflow is currently OPEN; SOD is complete and EOD is pending. Truck entry and all operational activities are permitted.";
            return;
        }

        gate.classList.add("blocked");
        if (!isSodDone) {
            gate.textContent = "Action Required: Complete Start of Day to unblock truck entry and workflow operations.";
        } else if (isEodDone) {
            gate.textContent = "Workflow is CLOSED: End of Day already completed. Next workflow operations are blocked until next SOD.";
        } else {
            gate.textContent = "Workflow is BLOCKED.";
        }
    }

    function renderHistory(rows) {
        var body = document.getElementById("sodHistoryBody");
        var empty = document.getElementById("sodHistoryEmpty");
        if (!body) return;

        var normalized = dedupeHistory(rows || []);
        var signature = normalized.map(function (r) {
            return [r.tasDayId, r.startDateTime, r.endDateTime].join("#");
        }).join("|");

        if (!normalized.length) {
            body.innerHTML = "";
            if (empty) {
                empty.style.display = "block";
                empty.textContent = "No records found.";
            }
            lastHistorySignature = "";
            selectedHistoryKey = null;
            return;
        }

        if (signature === lastHistorySignature) {
            applyHistorySelection();
            return;
        }

        lastHistorySignature = signature;
        if (empty) empty.style.display = "none";
        body.innerHTML = normalized.map(function (r) {
            var key = getHistoryKey(r);
            return '<div class="table-row" data-key="' + esc(key) + '" onclick="onHistoryRowClick(\'' + escJs(key) + '\')">' +
                '<div>' + esc(r.dayDate) + '</div>' +
                '<div>' + esc(fmtDateTime(r.startDateTime)) + '</div>' +
                '<div>' + (r.endDateTime ? esc(fmtDateTime(r.endDateTime)) : "—") + '</div>' +
                '</div>';
        }).join("");
        applyHistorySelection();
    }

    function dedupeHistory(rows) {
        var seen = Object.create(null);
        var out = [];
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i] || {};
            var key = String(r.tasDayId != null ? r.tasDayId : "") + "|" +
                String(r.startDateTime != null ? r.startDateTime : "") + "|" +
                String(r.endDateTime != null ? r.endDateTime : "");
            if (seen[key]) continue;
            seen[key] = true;
            out.push(r);
        }
        return out;
    }

    function getHistoryKey(r) {
        return String(r.tasDayId != null ? r.tasDayId : "") + "|" + String(r.startDateTime != null ? r.startDateTime : "");
    }

    function onHistoryRowClick(key) {
        selectedHistoryKey = selectedHistoryKey === key ? null : key;
        applyHistorySelection();
    }

    function applyHistorySelection() {
        document.querySelectorAll("#sodHistoryBody .table-row").forEach(function (row) {
            row.classList.toggle("sod-selected", selectedHistoryKey != null && row.dataset.key === selectedHistoryKey);
        });
    }

    function startDay() {
        if (sodRequestInFlight) return;
        sodRequestInFlight = true;
        var btn = document.getElementById("btnStartDay");
        if (btn) btn.disabled = true;

        fetch("/SODEOD/StartDay", {
            method: "POST",
            headers: { "Content-Type": "application/json" }
        })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.success) {
                    loadSODEODStatus();
                    return;
                }
                showSodNotice(res.message || "Start of Day failed.");
            })
            .catch(function () {
                showSodNotice("Start of Day failed.");
            })
            .finally(function () {
                sodRequestInFlight = false;
                loadSODEODStatus();
            });
    }

    function endDay() {
        if (eodRequestInFlight) return;
        eodRequestInFlight = true;
        var btn = document.getElementById("btnEndDay");
        if (btn) btn.disabled = true;

        fetch("/SODEOD/EndDay", {
            method: "POST",
            headers: { "Content-Type": "application/json" }
        })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.success) {
                    loadSODEODStatus();
                    return;
                }
                showSodNotice(res.message || "End of Day failed.");
            })
            .catch(function () {
                showSodNotice("End of Day failed.");
            })
            .finally(function () {
                eodRequestInFlight = false;
                loadSODEODStatus();
            });
    }

    function fmtDateTime(v) {
        if (!v) return "";
        var d = new Date(v);
        if (isNaN(d.getTime())) return String(v);
        var dd = String(d.getDate()).padStart(2, "0");
        var mm = String(d.getMonth() + 1).padStart(2, "0");
        var yy = d.getFullYear();
        var hh = String(d.getHours()).padStart(2, "0");
        var mi = String(d.getMinutes()).padStart(2, "0");
        var ss = String(d.getSeconds()).padStart(2, "0");
        return dd + "/" + mm + "/" + yy + " " + hh + ":" + mi + ":" + ss;
    }

    function esc(s) {
        if (s == null && s !== 0) return "";
        return String(s)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }

    function escJs(s) {
        if (s == null && s !== 0) return "";
        return String(s).replace(/\\/g, "\\\\").replace(/'/g, "\\'");
    }

    function pick(obj) {
        if (!obj) return null;
        for (var i = 1; i < arguments.length; i++) {
            var key = arguments[i];
            if (Object.prototype.hasOwnProperty.call(obj, key)) {
                return obj[key];
            }
        }
        return null;
    }

    function showSodNotice(message) {
        document.getElementById("sodNoticeText").textContent = message || "";
        var modal = document.getElementById("sodNoticeModal");
        var backdrop = document.getElementById("sodNoticeBackdrop");
        if (!modal || !backdrop) return;
        modal.style.display = "block";
        backdrop.style.display = "block";
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                modal.classList.add("show");
                backdrop.classList.add("show");
            });
        });
    }

    function closeSodNoticeModal() {
        var modal = document.getElementById("sodNoticeModal");
        var backdrop = document.getElementById("sodNoticeBackdrop");
        if (!modal || !backdrop) return;
        modal.classList.remove("show");
        backdrop.classList.remove("show");
        setTimeout(function () {
            modal.style.display = "none";
            backdrop.style.display = "none";
        }, 220);
    }
</script>
