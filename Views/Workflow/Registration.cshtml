        gap: 7px;
        cursor: pointer;
        font-size: 13px;
        color: rgba(255,255,255,0.8);
        user-select: none;
    }

        .rg-radio-label input[type="radio"] {
            display: none;
        }

    .rg-radio-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.3);
