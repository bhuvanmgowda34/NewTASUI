@{
    ViewBag.Title = "Truck Registration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bay-module-card">
    <div class="bay-toggle">
        <div class="bay-tab rg-tab-btn active" id="tabSearch" onclick="switchTab('search')">Search Trucks</div>
        <div class="bay-tab rg-tab-btn" id="tabRegister" onclick="switchTab('register')">Register</div>
        <div class="bay-indicator"></div>
    </div>
    <div class="bay-content">
        <div class="te-grid">
            <div class="te-panel">

                <!-- ════════════════════════════════
                     PANEL: SEARCH TRUCKS
                ════════════════════════════════ -->
                <div id="panelSearch" class="rg-panel">
                    <div class="te-toolbar" style="margin-bottom:8px;">
                        <div class="te-search-wrap">
                            <label class="te-search-label">Truck Reg #</label>
                            <input type="text" id="truckSearch" class="glass-input te-search"
                                   placeholder="" oninput="filterSearchTable()" />
                            <button class="btn-secondary te-find-btn" onclick="filterSearchTable()">Find</button>
                            <button class="btn-secondary te-find-btn" onclick="loadSearchTable()">Refresh</button>
                            <button class="btn-primary" id="btnRegister" onclick="onRegisterClick()">Register</button>
                        </div>
                        <div class="te-toolbar-note">
                            Search the truck, select from the table and click Register &nbsp;&nbsp;
                            Pending Trucks to Register:&nbsp;<span id="pendingCount" style="color:#e10600;font-weight:700;">0</span>
                        </div>
                    </div>

                    <div class="te-subhead" style="margin-bottom:6px;">
                        <div class="te-subhead-title">Today's Trucks to Register</div>
                    </div>

                    <!-- 21-col table mirrors VW_CURRENTATTENDANCE data -->
                    <div class="bay-table rg-search-table" id="searchTrucksWrapper">
                        <div class="table-header">
                            <div>Sel</div>
                            <div>Atten Date</div>
                            <div>Time</div>
                            <div>Atte. Type</div>
                            <div>Truck No</div>
                            <div>Truck Type</div>
                            <div>Truck Key</div>
                            <div>Is Perm</div>
                            <div>Company Name</div>
                            <div>No Of Comp</div>
                            <div>Printed Tare</div>
                            <div>Printed Gross</div>
                            <div>Tanker Tare</div>
                            <div>Tanker Gross</div>
                            <div>CCOE Perm</div>
                            <div>Calibration Due</div>
                            <div>License Expiry</div>
                            @* <div>TT Status</div>
                            <div>Seq No</div>
                            <div>Response</div>
                            <div>Lic Info</div> *@
                        </div>
                        <div class="table-body" id="searchTruckBody">
                            <div class="table-empty" id="searchTruckEmpty">Loading...</div>
                        </div>
                    </div>
                </div>

                <!-- ════════════════════════════════
                     PANEL: REGISTER
                ════════════════════════════════ -->
                <div id="panelRegister" class="rg-panel" style="display:none;">

                    <!-- Op Type bar -->
                    <div class="rg-optype-bar">
                        <span class="rg-optype-label">Operation Type</span>
                        <label class="rg-radio-label">
                            <input type="radio" name="opType" value="1" id="opLoading" checked onchange="onOpTypeChange()" />
                            <span class="rg-radio-dot"></span>
                            Loading
                        </label>
                        <label class="rg-radio-label">
                            <input type="radio" name="opType" value="2" id="opUnloading" onchange="onOpTypeChange()" />
                            <span class="rg-radio-dot"></span>
                            Unloading
                        </label>
                        <div style="flex:1"></div>
                        <button class="btn-primary" onclick="onSaveClick()">Save</button>
                        <button class="btn-secondary" onclick="onClearRegister()">Clear</button>
                    </div>

                    <!-- Truck Details card -->
                    <div class="rg-card">
                        <div class="rg-card-title">Truck Details</div>
                        <div class="rg-details-grid">
                            <div class="rg-detail-row">
                                <span class="rg-dl">Truck #</span>
                                <span class="rg-dv" id="dtTruckNum">&mdash;</span>
                                <span class="rg-dl">Num Of Compartments</span>
                                <span class="rg-dv" id="dtNoOfComp">&mdash;</span>
                                <span class="rg-dl">CCOE Permit Wt</span>
                                <span class="rg-dv" id="dtCCOE">&mdash;</span>
                            </div>
                            <div class="rg-detail-row">
                                <span class="rg-dl">Truck Type</span>
                                <span class="rg-dv" id="dtTruckType">&mdash;</span>
                                <span class="rg-dl">Printed Tare Wt</span>
                                <span class="rg-dv" id="dtPrintedTare">&mdash;</span>
                                <span class="rg-dl">Tanker Tare Wt</span>
                                <span class="rg-dv" id="dtTankerTare">&mdash;</span>
                            </div>
                            <div class="rg-detail-row">
                                <span class="rg-dl">Entered Date Time</span>
                                <span class="rg-dv" id="dtEnteredDate">&mdash;</span>
                                <span class="rg-dl">Printed Gross Wt</span>
                                <span class="rg-dv" id="dtPrintedGross">&mdash;</span>
                                <span class="rg-dl">Tanker Gross Wt</span>
                                <span class="rg-dv" id="dtTankerGross">&mdash;</span>
                            </div>
                            <div class="rg-detail-row">
                                <span class="rg-dl">Truck Key</span>
                                <span class="rg-dv" id="dtTruckKey">&mdash;</span>
                                <span class="rg-dl">Calibration Due Date</span>
                                <span class="rg-dv" id="dtCalib">&mdash;</span>
                                <span class="rg-dl">License Expiry Date</span>
                                <span class="rg-dv" id="dtLicense">&mdash;</span>
                            </div>
                            <div class="rg-detail-row">
                                <span class="rg-dl">Company Name</span>
                                <span class="rg-dv" id="dtCompany">&mdash;</span>
                                <span class="rg-dl"></span><span class="rg-dv"></span>
                                <span class="rg-dl"></span><span class="rg-dv"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Registration Details card -->
                    <div class="rg-card">
                        <div class="rg-card-title">Registration Details</div>
                        <div class="rg-reg-row">
                            <div class="rg-field-group">
                                <label class="rg-field-label">Registration #</label>
                                <input type="text" id="regNumber" class="rg-reg-input" readonly />
                            </div>
                            <div class="rg-field-group" style="min-width:200px;">
                                <label class="rg-field-label">Oil Company <span class="req">*</span></label>
                                <div class="rg-dd" id="oilCompanySelect">
                                    <div class="rg-dd-trigger" onclick="toggleDd('oilCompanySelect')">
                                        <span id="oilCompanyLabel">Select</span>
                                        <span class="rg-caret">&#9660;</span>
                                    </div>
                                    <div class="rg-dd-list" id="oilCompanyDropdown">
                                        <div class="option" data-disabled="1">Loading...</div>
                                    </div>
                                </div>
                            </div>
                            <div class="rg-field-group" style="min-width:170px;">
                                <label class="rg-field-label">Plant Code</label>
                                <div class="rg-dd" id="plantSelect">
                                    <div class="rg-dd-trigger" onclick="toggleDd('plantSelect')">
                                        <span id="plantLabel">Select</span>
                                        <span class="rg-caret">&#9660;</span>
                                    </div>
                                    <div class="rg-dd-list" id="plantDropdown">
                                        <div class="option" data-disabled="1">Loading...</div>
                                    </div>
                                </div>
                            </div>
                            <div class="rg-field-group" style="min-width:150px;">
                                <label class="rg-field-label">Plant Desc</label>
                                <input type="text" id="plantDesc" class="rg-reg-input" readonly />
                            </div>
                            <div class="rg-field-group">
                                <label class="rg-field-label">Registered By</label>
                                <span style="font-size:13px;color:#6f8cff;font-weight:600;line-height:34px;">Administrator</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bulk Loading card (visible for Loading op) -->
                    <div class="rg-card" id="loadingSection">
                        <div class="rg-bulk-tabstrip">
                            <div class="rg-bulk-tab active">Bulk Loading</div>
                        </div>

                        <!-- Single / Multiple -->
                        <div class="rg-mode-bar">
                            <label class="rg-radio-label">
                                <input type="radio" name="loadMode" value="single" id="modeS" checked onchange="onLoadModeChange()" />
                                <span class="rg-radio-dot"></span>
                                Single
                            </label>
                            <label class="rg-radio-label">
                                <input type="radio" name="loadMode" value="multiple" id="modeM" onchange="onLoadModeChange()" />
                                <span class="rg-radio-dot"></span>
                                Multiple
                            </label>
                        </div>

                        <!-- Single mode fields -->
                        <div id="singleModeFields">
                            <div class="rg-form-grid">
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Transporter Code</label>
                                    <div class="rg-dd" id="transporterSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('transporterSelect')">
                                            <span id="transporterLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="transporterDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Transporter Desc</label>
                                    <input type="text" id="transporterDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Shipment No</label>
                                    <input type="text" id="shipmentNo" class="rg-text-input" />
                                </div>
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Destination Code</label>
                                    <div class="rg-dd" id="destinationSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('destinationSelect')">
                                            <span id="destinationLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="destinationDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Destination Desc</label>
                                    <input type="text" id="destinationDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Customer Code</label>
                                    <div class="rg-dd" id="customerSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('customerSelect')">
                                            <span id="customerLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="customerDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Location Code</label>
                                    <div class="rg-dd" id="locationSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('locationSelect')">
                                            <span id="locationLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="locationDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Location Desc</label>
                                    <input type="text" id="locationDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Customer Desc</label>
                                    <input type="text" id="customerDesc" class="rg-text-input" readonly />
                                </div>
                            </div>
                        </div>

                        <!-- Multiple mode fields -->
                        <div id="multipleModeFields" style="display:none;">
                            <div class="rg-form-grid">
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Transporter Code</label>
                                    <div class="rg-dd" id="mTransporterSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('mTransporterSelect')">
                                            <span id="mTransporterLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="mTransporterDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Transporter Desc</label>
                                    <input type="text" id="mTransporterDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Shipment No</label>
                                    <input type="text" id="mShipmentNo" class="rg-text-input" />
                                </div>
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Destination Code</label>
                                    <div class="rg-dd" id="mDestinationSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('mDestinationSelect')">
                                            <span id="mDestinationLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="mDestinationDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Destination Desc</label>
                                    <input type="text" id="mDestinationDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Customer Code</label>
                                    <div class="rg-dd" id="mCustomerSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('mCustomerSelect')">
                                            <span id="mCustomerLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="mCustomerDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="rg-form-col">
                                    <label class="rg-field-label">Location Code</label>
                                    <div class="rg-dd" id="mLocationSelect">
                                        <div class="rg-dd-trigger" onclick="toggleDd('mLocationSelect')">
                                            <span id="mLocationLabel">Select</span>
                                            <span class="rg-caret">&#9660;</span>
                                        </div>
                                        <div class="rg-dd-list" id="mLocationDropdown">
                                            <div class="option" data-disabled="1">Loading...</div>
                                        </div>
                                    </div>
                                    <label class="rg-field-label" style="margin-top:10px;">Location Desc</label>
                                    <input type="text" id="mLocationDesc" class="rg-text-input" readonly />
                                    <label class="rg-field-label" style="margin-top:10px;">Customer Desc</label>
                                    <input type="text" id="mCustomerDesc" class="rg-text-input" readonly />
                                </div>
                            </div>
                        </div>

                        <!-- Loading Details subhead + table -->
                        <div class="rg-loading-subhead">Loading Details</div>
                        <div class="bay-table rg-loading-table" id="loadingTableWrapper">
                            <div class="table-header" id="loadingTableHeader">
                                <div>Compartment No</div>
                                <div>Material Code</div>
                                <div>Booked Quantity</div>
                            </div>
                            <div class="table-body" id="loadingTableBody">
                                <div class="table-empty" id="loadingTableEmpty">Select a truck to populate compartment details.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Unloading placeholder -->
                    <div class="rg-card" id="unloadingSection" style="display:none;">
                        <div class="rg-card-title">Unloading</div>
                        <div style="padding:30px;text-align:center;color:rgba(255,255,255,0.28);font-size:13px;">
                            Unloading section — coming soon.
                        </div>
                    </div>

                </div><!-- /panelRegister -->
            </div>
        </div>
    </div>
</div>

<!-- ══ MODAL: No Selection ══ -->
<div class="bcum-backdrop" id="rgNoSelBackdrop"></div>
<div class="bcum-modal te-modal" id="rgNoSelModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon te-warn-icon">&#9888;</span> Selection Required</div>
        <button class="bcum-close" onclick="rgClose('rgNoSelModal','rgNoSelBackdrop')">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text">Please select a truck to perform this action.</p>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-primary" onclick="rgClose('rgNoSelModal','rgNoSelBackdrop')">OK</button>
    </div>
</div>

<!-- ══ MODAL: Manual Registration ══ -->
<div class="bcum-backdrop" id="rgManualBackdrop"></div>
<div class="bcum-modal te-modal" id="rgManualModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon">&#9998;</span> Manual Registration</div>
        <button class="bcum-close" onclick="rgClose('rgManualModal','rgManualBackdrop')">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text" style="margin-bottom:6px;">Please select reason for Manual Registration</p>
        <div class="form-group">
            <label class="te-field-label">Reason <span class="req">*</span></label>
            <div class="te-modal-select" id="regReasonSelect">
                <div class="select-trigger" id="regReasonTrigger" onclick="toggleRegReasonSelect()">
                    <span id="regReasonLabel">Select Reason</span>
                </div>
                <div class="select-dropdown" id="regReasonDropdown">
                    <div class="option" data-disabled="1">Loading...</div>
                </div>
            </div>
        </div>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-secondary" onclick="rgClose('rgManualModal','rgManualBackdrop')">CLOSE</button>
        <button class="btn-primary" id="btnDoRegister" onclick="onDoRegister()">Register</button>
    </div>
</div>

<!-- ══ MODAL: SOD Warning ══ -->
<div class="bcum-backdrop" id="rgSodBackdrop"></div>
<div class="bcum-modal te-modal" id="rgSodModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon te-warn-icon">&#9888;</span> Attention Required</div>
        <button class="bcum-close" onclick="rgClose('rgSodModal','rgSodBackdrop')">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text">Start of Day (SOD) not done. Cannot register truck.</p>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-primary" onclick="rgClose('rgSodModal','rgSodBackdrop')">OK</button>
    </div>
</div>

<!-- ══ MODAL: Success ══ -->
<div class="bcum-backdrop" id="rgSuccessBackdrop"></div>
<div class="bcum-modal te-modal" id="rgSuccessModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon" style="color:#6f8cff;">&#10003;</span> Registration Successful</div>
        <button class="bcum-close" onclick="onSuccessOk()">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text" id="rgSuccessText">Truck Registered Successfully.</p>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-primary" onclick="onSuccessOk()">OK</button>
    </div>
</div>

<!-- ══ MODAL: Error / Info ══ -->
<div class="bcum-backdrop" id="rgErrBackdrop"></div>
<div class="bcum-modal te-modal" id="rgErrModal">
    <div class="bcum-header">
        <div class="bcum-title"><span class="bcum-icon te-warn-icon">&#9888;</span> Notice</div>
        <button class="bcum-close" onclick="rgClose('rgErrModal','rgErrBackdrop')">&#10005;</button>
    </div>
    <div class="bcum-body te-modal-body">
        <p class="te-confirm-text" id="rgErrText"></p>
    </div>
    <div class="bcum-footer">
        <div style="flex:1"></div>
        <button class="btn-primary" onclick="rgClose('rgErrModal','rgErrBackdrop')">OK</button>
    </div>
</div>


<!-- ═══════════════════════════════
     STYLES
═══════════════════════════════ -->
<style>
    /* ── Layout ── */
    .te-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
        flex: 1;
        min-height: 0;
        box-sizing: border-box;
    }

    .te-panel {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
        width: 100%;
        flex: 1;
        min-height: 0;
    }

    .rg-panel {
        flex: 1;
        min-height: 0;
        flex-direction: column;
    }

    #panelSearch.rg-panel {
        display: flex;
    }

    #panelRegister.rg-panel {
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 6px;
    }

    /* ── Tabs ── */
    .bay-tab.rg-tab-btn {
        cursor: pointer;
    }

    /* ── Toolbar ── */
    .te-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: nowrap;
    }

    .te-search-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: 0 1 auto;
        min-width: 0;
        white-space: nowrap;
    }

    .te-search-label {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.82);
        white-space: nowrap;
    }

    .te-search {
        flex: 0 0 140px;
        height: 36px;
        padding: 0 12px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: #fff;
        font-size: 12px;
        box-sizing: border-box;
        outline: none;
    }

        .te-search:focus {
            border-color: rgba(225,6,0,0.5);
            box-shadow: 0 0 0 2px rgba(225,6,0,0.1);
        }

    .te-find-btn {
        height: 36px;
        padding: 0 14px;
        white-space: nowrap;
        font-size: 12px;
    }

    .te-toolbar-note {
        flex: 1;
        text-align: center;
        font-size: 13px;
        font-weight: 600;
        color: #6f8cff;
        white-space: nowrap;
    }

    .te-subhead {
        display: flex;
        align-items: center;
        gap: 30px;
        padding: 0 2px;
    }

    .te-subhead-title {
        font-size: 13px;
        font-weight: 600;
        color: #6f8cff;
        white-space: nowrap;
    }

    /* ── Search table — 17 cols ── */
    .rg-search-table .table-header,
    .rg-search-table .table-row {
        grid-template-columns: 44px 100px 84px 80px 126px 88px 88px 76px 130px 90px 100px 106px 100px 106px 96px 110px 110px;
        font-size: 11px;
    }

    .rg-search-table {
        flex: 1;
        min-height: 160px;
        height: auto;
        max-height: none;
        overflow-y: hidden;
    }

        .rg-search-table .table-body {
            overflow-y: auto !important;
            flex: 1;
            min-height: 0;
            max-height: none;
        }

        .rg-search-table .table-header div,
        .rg-search-table .table-row div {
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 6px;
            box-sizing: border-box;
            min-width: 0;
        }

        .rg-search-table .table-row {
            cursor: pointer;
        }

            .rg-search-table .table-row:hover {
                background: rgba(255,255,255,0.04);
            }

            .rg-search-table .table-row.te-selected {
