    .te-status-n {
        color: rgba(255,255,255,0.2);
        font-size: 12px;
    }

    .te-lic-ok {
        color: rgba(255,255,255,0.75);
    }

    .te-lic-warn {
        color: #ffd600;
    }

    .te-lic-exp {
        color: #ff5555;
    }

    .table-empty {
        padding: 28px;
        text-align: center;
        color: rgba(255,255,255,0.28);
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    /* ── Op type bar ── */
    .rg-optype-bar {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 10px 16px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
