    /* ── Scrollbars ── */
    .bay-table::-webkit-scrollbar {
        height: 6px;
        width: 6px;
    }

    .bay-table::-webkit-scrollbar-track {
        background: transparent;
    }

    .bay-table::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg,rgba(255,255,255,0.25),rgba(255,255,255,0.08));
        border-radius: 10px;
    }

    .bay-table::-webkit-scrollbar-corner {
