    /* ── Buttons ── */
    .btn-primary {
        position: relative;
        padding: 8px 18px;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        background: linear-gradient(180deg,#ff4d4d 0%,#ff1f1f 40%,#cc0000 70%,#990000 100%);
        color: #fff;
        font-size: 12px;
        font-weight: 500;
        box-shadow: 0 4px 10px rgba(0,0,0,0.4),0 0 8px rgba(255,0,0,0.25);
        transition: all 0.15s ease;
    }

        .btn-primary:hover {
            filter: brightness(1.1);
        }

        .btn-primary:active {
            transform: scale(0.95) translateY(1px);
        }

