    .rg-radio-dot::after {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fff;
        opacity: 0;
        transform: scale(0.4);
        transition: all 0.18s;
    }

    .rg-radio-label input:checked + .rg-radio-dot::after {
        opacity: 1;
        transform: scale(1);
    }

    /* ── Cards ── */
    .rg-card {
