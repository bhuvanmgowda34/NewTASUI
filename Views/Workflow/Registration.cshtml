        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    /* ── Truck details grid ── */
    .rg-details-grid {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .rg-detail-row {
        display: grid;
        grid-template-columns: 150px 1fr 160px 1fr 150px 1fr;
        align-items: baseline;
        gap: 2px 8px;
    }

    .rg-dl {
        font-size: 11.5px;
        color: rgba(255,255,255,0.48);
        text-align: right;
        padding-right: 10px;
        white-space: nowrap;
    }

    .rg-dv {
        font-size: 13px;
        font-weight: 600;
        color: #6f8cff;
        white-space: nowrap;
    }

    /* ── Registration Details row ── */
    .rg-reg-row {
        display: flex;
        align-items: flex-end;
        gap: 28px;
        flex-wrap: wrap;
    }

    .rg-field-group {
        display: flex;
