    }

    .rg-text-input {
        height: 34px;
        padding: 0 10px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.03);
        color: rgba(255,255,255,0.7);
        font-size: 12px;
        box-sizing: border-box;
        outline: none;
        width: 100%;
    }

    /* ── Bulk Loading tabstrip ── */
    .rg-bulk-tabstrip {
        display: flex;
        margin-bottom: 14px;
        border-bottom: 0;
    }

    .rg-bulk-tab {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.55);
        padding: 6px 18px;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03);
        cursor: default;
    }

        .rg-bulk-tab.active {
            color: #e10600;
            border-color: rgba(225,6,0,0.35);
            border-bottom-color: rgba(225,6,0,0.35);
            background: rgba(225,6,0,0.10);
        }

    /* ── Mode bar ── */
    .rg-mode-bar {
        display: flex;
        align-items: center;
        gap: 22px;
        margin-bottom: 14px;
    }

    /* ── Form grid ── */
    .rg-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px 20px;
        margin-bottom: 4px;
    }

    .rg-form-col {
        display: flex;
        flex-direction: column;
    }

    /* ── Loading subhead ── */
    .rg-loading-subhead {
        font-size: 11px;
        font-weight: 700;
        color: #6f8cff;
        letter-spacing: 0.6px;
        text-transform: uppercase;
        margin: 16px 0 8px;
    }

    /* ── Loading table ── */
    .rg-loading-table {
        flex: 0 0 auto;
        min-height: 0;
        height: auto;
        max-height: none;
        overflow: visible !important;
        border-radius: 10px;
    }

        .rg-loading-table .table-body {
            width: 100% !important;
            height: auto;
            flex: 0 0 auto;
            min-height: 0;
            max-height: none;
            overflow: visible !important;
        }

        .rg-loading-table .bay-table {
            overflow: visible !important;
        }

        .rg-loading-table .table-header,
        .rg-loading-table .table-row {
            grid-template-columns: minmax(130px, 0.8fr) minmax(260px, 1.15fr) minmax(160px, 0.75fr);
            font-size: 12px;
            width: 100%;
            min-width: 0;
        }

        .rg-loading-table .table-header {
            min-height: 46px;
            padding: 0;
            z-index: 1;
        }

        .rg-loading-table.rg-loading-multiple .table-header,
        .rg-loading-table.rg-loading-multiple .table-row {
            grid-template-columns: minmax(120px, 0.75fr) minmax(250px, 1.15fr) minmax(150px, 0.75fr) minmax(130px, 0.72fr) minmax(160px, 0.85fr) minmax(130px, 0.72fr) minmax(160px, 0.85fr);
        }

            .rg-loading-table .table-header > div,
            .rg-loading-table .table-row > div {
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 10px;
                box-sizing: border-box;
                min-width: 0;
            }

        .rg-loading-table .table-row {
            cursor: default;
            min-height: 52px;
            padding: 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: relative;
            z-index: 1;
        }

        .rg-loading-table .table-row:has(.rg-prod-dd.open) {
            z-index: 100000;
        }

            .rg-loading-table .table-row:hover {
                background: rgba(255,255,255,0.025);
            }

    /* ── Product dropdown inside table ── */
    .rg-prod-dd {
        position: relative;
        width: min(100%, 360px);
        margin: 0 auto;
        z-index: 5;
    }

        .rg-prod-dd.open {
            z-index: 1000000;
        }

        .rg-prod-dd .rg-dd-trigger {
            height: 30px;
            padding: 0 10px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(255,255,255,0.04);
            color: #fff;
            font-size: 12px;
            box-sizing: border-box;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            min-width: 0;
            overflow: hidden;
        }

            .rg-prod-dd .rg-dd-trigger span:first-child {
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                min-width: 0;
            }

        .rg-prod-dd .rg-dd-list {
            display: none;
            position: absolute;
            top: calc(100% + 3px);
            bottom: auto;
            left: 0;
            width: max-content;
            min-width: 100%;
            max-width: 460px;
            background: #080808 !important;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            z-index: 999999;
            box-shadow: 0 10px 30px rgba(0,0,0,0.7);
            max-height: 180px;
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.36) transparent;
            isolation: isolate;
            backdrop-filter: none !important;
            -webkit-backdrop-filter: none !important;
            mix-blend-mode: normal;
            transform: translateZ(0);
        }

            .rg-prod-dd .rg-dd-list::before {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -1;
                background: #080808;
                border-radius: 8px;
            }

        .rg-prod-dd.drop-up .rg-dd-list {
            top: auto;
            bottom: calc(100% + 3px);
        }

            .rg-prod-dd .rg-dd-list::-webkit-scrollbar,
            .rg-dd-list::-webkit-scrollbar,
            #panelRegister::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }

            .rg-prod-dd .rg-dd-list::-webkit-scrollbar-track,
            .rg-dd-list::-webkit-scrollbar-track,
            #panelRegister::-webkit-scrollbar-track {
                background: transparent;
                margin: 8px 2px;
                border-radius: 10px;
            }

            .rg-prod-dd .rg-dd-list::-webkit-scrollbar-thumb,
            .rg-dd-list::-webkit-scrollbar-thumb,
            #panelRegister::-webkit-scrollbar-thumb {
                background: linear-gradient(180deg, rgba(255,255,255,0.48), rgba(255,255,255,0.24));
                border-radius: 10px;
                border: 1px solid rgba(0,0,0,0.25);
            }

                .rg-prod-dd .rg-dd-list::-webkit-scrollbar-thumb:hover,
                .rg-dd-list::-webkit-scrollbar-thumb:hover,
                #panelRegister::-webkit-scrollbar-thumb:hover {
                    background: linear-gradient(180deg, rgba(255,255,255,0.62), rgba(255,255,255,0.32));
                }

        .rg-prod-dd.open .rg-dd-list {
            display: block !important;
            background-color: #080808 !important;
        }

        .rg-prod-dd .rg-dd-list .option {
            position: relative;
            z-index: 1;
            display: block !important;
            padding: 8px 12px;
            font-size: 12px;
            line-height: 1.25;
            background: #080808;
            color: rgba(255,255,255,0.85);
            cursor: pointer;
            text-align: left !important;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            min-width: 0;
        }

            .rg-prod-dd .rg-dd-list .option:hover {
                background: rgba(255,255,255,0.08);
            }

    .rg-qty-input {
        height: 30px;
        padding: 0 8px;
        width: min(100%, 170px);
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: #fff;
        font-size: 12px;
        box-sizing: border-box;
        outline: none;
        text-align: center;
    }

        .rg-qty-input[readonly] {
            color: rgba(255,255,255,0.9);
            background: rgba(255,255,255,0.025);
            cursor: default;
        }

    /* ── rg-dd (general form dropdowns) ── */
    .rg-dd {
        position: relative;
        width: 100%;
        overflow: visible !important;
    }

    .rg-dd-trigger {
        height: 34px;
        padding: 0 10px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: #fff;
        font-size: 12px;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        width: 100%;
    }

    .rg-dd-list {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        width: 100%;
        min-width: 160px;
        background: rgba(18,18,18,0.99);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        z-index: 999999;
        box-shadow: 0 10px 30px rgba(0,0,0,0.65);
        max-height: 200px;
        overflow-y: auto;
