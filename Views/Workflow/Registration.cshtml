        font-size: 12px;
        cursor: pointer;
        box-shadow: 0 3px 8px rgba(0,0,0,0.35),inset 0 1px 0 rgba(255,255,255,0.1);
        transition: all 0.15s ease;
    }

        .btn-secondary:hover {
