            overflow-y: auto;
            opacity: 1 !important;
            visibility: visible !important;
            pointer-events: auto !important;
        }

    .te-modal-select.open .select-dropdown {
        display: block !important;
    }

    #regReasonSelect.open #regReasonDropdown {
        display: block !important;
        background: #080808 !important;
        z-index: 1000000 !important;
        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
    }

        .te-modal-select .select-dropdown .option {
            padding: 9px 14px;
            font-size: 12.5px;
            color: rgba(255,255,255,0.85);
            cursor: pointer;
        }

            .te-modal-select .select-dropdown .option:hover {
                background: rgba(255,255,255,0.08);
            }
</style>


<!-- ═══════════════════════════════
     JAVASCRIPT
═══════════════════════════════ -->
<script>
    /* ═══ STATE ═══ */
    var currentTab       = "search";
    var searchList       = [];
    var selectedAttId    = null;   // TruckAttendanceId
    var selectedTruckId  = null;
    var selectedTruckNum = null;
    var selectedAttRow   = null;   // full row object

    var productsList     = [];
    var oilCompList      = [];
    var plantList        = [];
    var transporterList  = [];
    var destinationList  = [];
    var locationList     = [];
    var customerList     = [];
    var regReasonList    = [];

    var compartmentRows  = [];     // [{compartmentNo, productId, productLabel, quantity}]

    /* ═══ INIT ═══ */
    document.addEventListener("DOMContentLoaded", function () {
        loadSearchTable();
        loadDropdownData();
        wireDropdowns();
    });

    /* ═══ TAB SWITCHING ═══ */
    function switchTab(tab) {
        currentTab = tab;
        var ts = document.getElementById("tabSearch");
        var tr = document.getElementById("tabRegister");
        var ps = document.getElementById("panelSearch");
        var pr = document.getElementById("panelRegister");
        if (tab === "search") {
            ts.classList.add("active");    tr.classList.remove("active");
            ps.style.display = "flex";     pr.style.display = "none";
            moveRgIndicator(ts);
        } else {
            ts.classList.remove("active"); tr.classList.add("active");
    ps.style.display = "none";     pr.style.display = "flex";
    pr.style.flexDirection = "column";
                moveRgIndicator(tr);
        }
    }

    function moveRgIndicator(tab) {
        var indicator = document.querySelector(".bay-toggle .bay-indicator");
        if (!tab || !indicator) return;
        var rect = tab.getBoundingClientRect();
        var parentRect = tab.parentElement.getBoundingClientRect();
        indicator.style.width = rect.width + "px";
        indicator.style.transform = "translateX(" + (rect.left - parentRect.left) + "px)";
    }

    /* ═══ SEARCH TABLE ═══ */
    function loadSearchTable() {
        setEmpty("searchTruckEmpty", "Loading...", true);
        fetch("/TruckRegistration/GetPendingRegistration")
            .then(function (r) { return r.json(); })
            .then(function (data) {
                searchList = data || [];
                document.getElementById("pendingCount").textContent = searchList.length;
                renderSearchTable();
            })
            .catch(function () { setEmpty("searchTruckEmpty", "Failed to load", true); });
    }

    function filterSearchTable() { renderSearchTable(); }

    function renderSearchTable() {
        var body = document.getElementById("searchTruckBody");
        var q    = (document.getElementById("truckSearch").value || "").trim().toLowerCase();
        var list = q ? searchList.filter(function (t) {
            return t.truckNumber && t.truckNumber.toLowerCase().indexOf(q) !== -1;
        }) : searchList;

        if (!list.length) { body.innerHTML = ""; setEmpty("searchTruckEmpty", "No pending registrations.", true); return; }
        setEmpty("searchTruckEmpty", "", false);

        body.innerHTML = list.map(function (t) {
            var sel     = t.truckEntryId === selectedAttId ? " te-selected" : "";
            var checked = sel ? "checked" : "";
            // var statusStr = (!t.ttStatus || t.ttStatus === "N")
            //     ? '<span class="te-status-n">&mdash; N</span>'
            //     : '<span class="te-status-y">&#10004; Y</span>';

            return '<div class="table-row' + sel + '" onclick="onSearchRowClick(' + t.truckEntryId + ',\'' + escJs(t.truckNumber) + '\',' + t.truckId + ')">' +
                '<div class="te-row-check"><input type="radio" ' + checked + '/><div class="te-radio-mark"></div></div>' +
                '<div>' + esc(t.entryDate)           + '</div>' +
                '<div>' + esc(t.time)                + '</div>' +
                '<div>' + esc(t.entryType)           + '</div>' +
                '<div>' + esc(t.truckNumber)         + '</div>' +
                '<div>' + esc(t.truckType)           + '</div>' +
                '<div>' + escVal(t.truckKey)         + '</div>' +
                '<div>' + (t.isPermanentKey ? '<span class="te-status-y">&#10004;</span>' : '&mdash;') + '</div>' +
                '<div>' + esc(t.companyName)         + '</div>' +
                '<div>' + escVal(t.noOfCompartments) + '</div>' +
                '<div>' + fmtD(t.printedTareWeight)  + '</div>' +
                '<div>' + fmtD(t.printedGrossWeight) + '</div>' +
                '<div>' + fmtD(t.tankerTareWeight)   + '</div>' +
                '<div>' + fmtD(t.tankerGrossWeight)  + '</div>' +
                '<div>' + fmtD(t.ccoePermWeight)     + '</div>' +
                '<div class="' + licClass(t.callibrationDueDate) + '">' + fmtDt(t.callibrationDueDate) + '</div>' +
                '<div class="' + licClass(t.licenseExpireDate)   + '">' + fmtDt(t.licenseExpireDate)   + '</div>' +
                // '<div>' + statusStr                  + '</div>' +
                // '<div>' + escVal(t.sequenceNumber)   + '</div>' +
                // '<div>' + esc(t.processingResponse)  + '</div>' +
                // '<div>' + esc(t.licenseExpiryInfo)   + '</div>' +
                '</div>';
        }).join("");
    }

    function onSearchRowClick(id, regNum, truckId) {
        if (selectedAttId === id) {
            selectedAttId = null; selectedTruckNum = null; selectedTruckId = null; selectedAttRow = null;
        } else {
            selectedAttId = id; selectedTruckNum = regNum; selectedTruckId = truckId;
            selectedAttRow = null;
            for (var i = 0; i < searchList.length; i++) { if (searchList[i].truckEntryId === id) { selectedAttRow = searchList[i]; break; } }
        }
        renderSearchTable();
    }

    /* ═══ REGISTER CLICK ═══ */
    function onRegisterClick() {
        if (!selectedAttId) { rgOpen("rgNoSelModal", "rgNoSelBackdrop"); return; }
        populateTruckDetails();
        loadNextRegNumber();
        switchTab("register");
    }

    function populateTruckDetails() {
        var t = selectedAttRow;
        if (!t) return;
        setInner("dtTruckNum",     esc(t.truckNumber) || "&mdash;");
        setInner("dtTruckType",    esc(t.truckType)   || "&mdash;");
        setInner("dtEnteredDate",  esc((t.entryDate || "") + " " + (t.time || "")));
        setInner("dtTruckKey",     escVal(t.truckKey));
        setInner("dtCompany",      esc(t.companyName) || "&mdash;");
        setInner("dtNoOfComp",     t.noOfCompartments != null ? String(t.noOfCompartments) : "&mdash;");
        setInner("dtPrintedTare",  t.printedTareWeight  != null ? parseFloat(t.printedTareWeight).toFixed(2)  : "&mdash;");
        setInner("dtPrintedGross", t.printedGrossWeight != null ? parseFloat(t.printedGrossWeight).toFixed(2) : "&mdash;");
        setInner("dtCalib",        fmtDt(t.callibrationDueDate));
        setInner("dtCCOE",         t.ccoePermWeight   != null ? parseFloat(t.ccoePermWeight).toFixed(2)   : "&mdash;");
        setInner("dtTankerTare",   t.tankerTareWeight != null ? parseFloat(t.tankerTareWeight).toFixed(2) : "&mdash;");
        setInner("dtTankerGross",  t.tankerGrossWeight!= null ? parseFloat(t.tankerGrossWeight).toFixed(2): "&mdash;");
        setInner("dtLicense",      fmtDt(t.licenseExpireDate));

        // Build compartment rows from truck master capacities when available.
        var n = t.noOfCompartments || 1;
        compartmentRows = [];
        for (var i = 1; i <= n; i++) {
            compartmentRows.push({ compartmentNo: i, productId: null, productLabel: "", quantity: 0 });
        }
        renderLoadingTable();
        loadTruckCompartments();
    }

    function loadTruckCompartments() {
        if (!selectedTruckId) return;
        fetch("/TruckRegistration/GetTruckCompartments?truckId=" + encodeURIComponent(selectedTruckId))
            .then(function (r) { return r.json(); })
            .then(function (rows) {
                if (!Array.isArray(rows) || !rows.length) return;
                for (var i = 0; i < compartmentRows.length; i++) {
                    for (var j = 0; j < rows.length; j++) {
                        if (Number(rows[j].compartmentNo) === Number(compartmentRows[i].compartmentNo)) {
                            compartmentRows[i].quantity = parseInt(rows[j].capacity, 10) || 0;
                            break;
                        }
                    }
                }
                renderLoadingTable();
            });
    }

    function setInner(id, html) { var el = document.getElementById(id); if (el) el.innerHTML = html; }

    /* ═══ NEXT REG NUMBER ═══ */
    function loadNextRegNumber() {
        fetch("/TruckRegistration/GetNextRegistrationNumber")
            .then(function (r) { return r.json(); })
            .then(function (d) { document.getElementById("regNumber").value = d.nextNumber || ""; });
    }

    /* ═══ OP TYPE / LOAD MODE ═══ */
    function onOpTypeChange() {
        var isUnload = document.getElementById("opUnloading").checked;
        document.getElementById("loadingSection").style.display   = isUnload ? "none" : "";
        document.getElementById("unloadingSection").style.display = isUnload ? ""     : "none";
    }

    function onLoadModeChange() {
        var multi = document.getElementById("modeM").checked;
        document.getElementById("singleModeFields").style.display   = multi ? "none" : "";
        document.getElementById("multipleModeFields").style.display = multi ? ""     : "none";
        renderLoadingTable();
    }

    /* ═══ LOADING TABLE ═══ */
    function renderLoadingTable() {
        var body = document.getElementById("loadingTableBody");
        var header = document.getElementById("loadingTableHeader");
        var wrapper = document.getElementById("loadingTableWrapper");
        var multi = document.getElementById("modeM") && document.getElementById("modeM").checked;

        if (wrapper) wrapper.classList.toggle("rg-loading-multiple", !!multi);
        if (header) {
            header.innerHTML = multi
                ? '<div>Compartment No</div><div>Material Code</div><div>Booked Quantity</div><div>CustomerCode</div><div>CustomerDesc</div><div>DestinationCode</div><div>DestinationDesc</div>'
                : '<div>Compartment No</div><div>Material Code</div><div>Booked Quantity</div>';
        }

        setEmpty("loadingTableEmpty", "", false);

        if (!compartmentRows.length) {
            body.innerHTML = "";
            setEmpty("loadingTableEmpty", "No compartments.", true);
            return;
        }

        var custCode  = multi ? (document.getElementById("mCustomerSelect").getAttribute("data-val") || "") : "";
        var custDesc  = multi ? (document.getElementById("mCustomerDesc").value || "") : "";
        var destCode  = multi ? (document.getElementById("mDestinationSelect").getAttribute("data-val") || "") : "";
        var destDesc  = multi ? (document.getElementById("mDestinationDesc").value || "") : "";

        body.innerHTML = compartmentRows.map(function (row, idx) {
            var ddId  = "prodDd_"  + idx;
            var lblId = "prodLbl_" + idx;
            var qtyId = "qty_"     + idx;
            var productCell =
                '<div style="padding:5px 8px;">' +
                  '<div class="rg-prod-dd" id="' + ddId + '">' +
                    '<div class="rg-dd-trigger" onclick="toggleProdDd(\'' + ddId + '\')">' +
                      '<span id="' + lblId + '">' + (row.productLabel || "Select Product") + '</span>' +
                      '<span class="rg-caret">&#9660;</span>' +
                    '</div>' +
                    '<div class="rg-dd-list" id="' + ddId + '_list">' +
                      buildProductOptions(idx, ddId, lblId) +
                    '</div>' +
                  '</div>' +
                '</div>';
            var qtyCell =
                '<div style="padding:5px 8px;">' +
                  '<input type="number" id="' + qtyId + '" class="rg-qty-input" min="0" value="' + row.quantity + '" readonly />' +
                '</div>';

            if (multi) {
                return '<div class="table-row">' +
                    '<div>' + row.compartmentNo + '</div>' +
                    productCell +
                    qtyCell +
                    '<div>' + escVal(custCode) + '</div>' +
                    '<div>' + escVal(custDesc) + '</div>' +
                    '<div>' + escVal(destCode) + '</div>' +
                    '<div>' + escVal(destDesc) + '</div>' +
                '</div>';
            }

            return '<div class="table-row">' +
                '<div>' + row.compartmentNo + '</div>' +
                productCell +
                qtyCell +
                '</div>';
        }).join("");
    }

    function buildProductOptions(rowIdx, ddId, lblId) {
        if (!productsList.length) return '<div class="option" data-disabled="1">No products loaded</div>';
        return productsList.map(function (p) {
            var display = p.productCode + (p.productName ? ' - ' + p.productName : '');
            return '<div class="option" title="' + escAttr(display) + '" onclick="selectProduct(' + rowIdx + ',' + p.productId + ',\'' + escJs(display) + '\',\'' + ddId + '\',\'' + lblId + '\')">' +
                esc(display) + '</div>';
        }).join("");
    }

    function toggleProdDd(id) {
        var el = document.getElementById(id);
        if (!el) return;
        var wasOpen = el.classList.contains("open");
        var all = document.querySelectorAll(".rg-prod-dd.open");
        for (var i = 0; i < all.length; i++) {
            all[i].classList.remove("open");
            all[i].classList.remove("drop-up");
        }
        if (!wasOpen) {
            var rect = el.getBoundingClientRect();
            var panel = document.getElementById("panelRegister");
            var panelRect = panel ? panel.getBoundingClientRect() : { bottom: window.innerHeight };
            var spaceBelow = Math.min(window.innerHeight, panelRect.bottom) - rect.bottom;
            var spaceAbove = rect.top - (panel ? panelRect.top : 0);
            if (spaceBelow < 210 && spaceAbove > spaceBelow) el.classList.add("drop-up");
            el.classList.add("open");
        }
    }

    function selectProduct(rowIdx, productId, productLabel, ddId, lblId) {
        compartmentRows[rowIdx].productId    = productId;
        compartmentRows[rowIdx].productLabel = productLabel;
        var lbl = document.getElementById(lblId);
        if (lbl) lbl.textContent = productLabel;
        var dd = document.getElementById(ddId);
        if (dd) dd.classList.remove("open");
    }

    /* ═══ SAVE CLICK ═══ */
    function onSaveClick() {
        var oilCo = document.getElementById("oilCompanySelect").getAttribute("data-val");
        if (!oilCo) { rgShowMsg("Please select Oil Company."); return; }

        // Validate compartments
        for (var i = 0; i < compartmentRows.length; i++) {
            if (!compartmentRows[i].productId) {
                rgShowMsg("Please select Material Code for Compartment " + compartmentRows[i].compartmentNo + "."); return;
            }
        }

        // Load reasons if needed, then open modal
        if (!regReasonList.length) {
            loadRegReasons(function () { openManualModal(); });
        } else {
            openManualModal();
        }
    }

    function openManualModal() {
        document.getElementById("regReasonLabel").textContent = "Select Reason";
        document.getElementById("regReasonSelect").removeAttribute("data-val");
        renderRegReasons();
        rgOpen("rgManualModal", "rgManualBackdrop");
    }

    function selectRegReason(val) {
        document.getElementById("regReasonLabel").textContent = val;
        document.getElementById("regReasonSelect").setAttribute("data-val", val);
        document.getElementById("regReasonSelect").classList.remove("open");
    }

    function toggleRegReasonSelect() {
        var sel = document.getElementById("regReasonSelect");
        if (!sel) return false;
        var isOpen = sel.classList.contains("open");
        document.querySelectorAll(".te-modal-select.open, .rg-dd.open, .rg-prod-dd.open").forEach(function (s) {
            s.classList.remove("open");
            s.classList.remove("drop-up");
        });
        if (!isOpen) sel.classList.add("open");
        return false;
    }

    /* ═══ DO REGISTER ═══ */
    function onDoRegister() {
        var reason = document.getElementById("regReasonSelect").getAttribute("data-val");
        if (!reason) { rgShowMsg("Please select a reason."); return; }

        var btn = document.getElementById("btnDoRegister");
        btn.disabled = true; btn.textContent = "Registering...";

        var multi = document.getElementById("modeM").checked;
        var oilCo = document.getElementById("oilCompanySelect").getAttribute("data-val") || "";
        var plantCode = document.getElementById("plantSelect").getAttribute("data-val") || "";
        var plantDesc = document.getElementById("plantDesc").value || "";
        var transCode, transDesc, destCode, destDesc, locCode, locDesc, custCode, custDesc, shipNo;

        if (!multi) {
            transCode = document.getElementById("transporterSelect").getAttribute("data-val") || "";
            transDesc = document.getElementById("transporterDesc").value || "";
            destCode  = document.getElementById("destinationSelect").getAttribute("data-val") || "";
            destDesc  = document.getElementById("destinationDesc").value || "";
            locCode   = document.getElementById("locationSelect").getAttribute("data-val") || "";
            locDesc   = document.getElementById("locationDesc").value || "";
            custCode  = document.getElementById("customerSelect").getAttribute("data-val") || "";
            custDesc  = document.getElementById("customerDesc").value || "";
            shipNo    = document.getElementById("shipmentNo").value || "";
        } else {
            transCode = document.getElementById("mTransporterSelect").getAttribute("data-val") || "";
            transDesc = document.getElementById("mTransporterDesc").value || "";
            destCode  = document.getElementById("mDestinationSelect").getAttribute("data-val") || "";
            destDesc  = document.getElementById("mDestinationDesc").value || "";
            locCode   = document.getElementById("mLocationSelect").getAttribute("data-val") || "";
            locDesc   = document.getElementById("mLocationDesc").value || "";
            custCode  = document.getElementById("mCustomerSelect").getAttribute("data-val") || "";
            custDesc  = document.getElementById("mCustomerDesc").value || "";
            shipNo    = document.getElementById("mShipmentNo").value || "";
        }

        var payload = {
            truckAttendanceId: selectedAttId,
            truckId:           selectedTruckId,
            operationTypeId:   document.getElementById("opLoading").checked ? 1 : 2,
            oilCompany:        oilCo,
            plantCode:         plantCode,
            plantDesc:         plantDesc,
            transporterCode:   transCode,
            transporterDesc:   transDesc,
            destinationCode:   destCode,
            destinationDesc:   destDesc,
            locationCode:      locCode,
            locationDesc:      locDesc,
            customerCode:      custCode,
            customerDesc:      custDesc,
            shipmentNo:        shipNo,
            reason:            reason,
            compartments:      compartmentRows.map(function (r) {
                return { compartmentNo: r.compartmentNo, productId: r.productId, quantity: r.quantity };
            })
        };

        fetch("/TruckRegistration/PostRegistration", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            btn.disabled = false; btn.textContent = "Register";
            if (res.success) {
                rgClose("rgManualModal", "rgManualBackdrop");
                document.getElementById("rgSuccessText").textContent =
                    "Truck Registered Successfully with registration no: " + res.registrationNumber;
                rgOpen("rgSuccessModal", "rgSuccessBackdrop");
            } else if (res.message === "NO_SOD") {
                rgClose("rgManualModal", "rgManualBackdrop");
                rgOpen("rgSodModal", "rgSodBackdrop");
            } else {
                rgShowMsg(res.message || "Registration failed.");
            }
        })
        .catch(function () { btn.disabled = false; btn.textContent = "Register"; rgShowMsg("Network error."); });
    }

    function onSuccessOk() {
        rgClose("rgSuccessModal", "rgSuccessBackdrop");
        selectedAttId = null; selectedTruckId = null; selectedTruckNum = null; selectedAttRow = null; compartmentRows = [];
        switchTab("search");
        loadSearchTable();
    }

    function onClearRegister() {
        if (selectedAttRow) populateTruckDetails();
        var dds = ["oilCompanySelect","plantSelect","transporterSelect","destinationSelect","locationSelect","customerSelect","mTransporterSelect","mDestinationSelect","mLocationSelect","mCustomerSelect"];
        var lbls= ["oilCompanyLabel","plantLabel","transporterLabel","destinationLabel","locationLabel","customerLabel","mTransporterLabel","mDestinationLabel","mLocationLabel","mCustomerLabel"];
        for (var i = 0; i < dds.length; i++) {
            var s = document.getElementById(dds[i]); if (s) s.removeAttribute("data-val");
            var l = document.getElementById(lbls[i]); if (l) l.textContent = "Select";
        }
        var txts = ["plantDesc","transporterDesc","destinationDesc","locationDesc","customerDesc","mTransporterDesc","mDestinationDesc","mLocationDesc","mCustomerDesc","shipmentNo","mShipmentNo"];
        for (var j = 0; j < txts.length; j++) { var fi = document.getElementById(txts[j]); if (fi) fi.value = ""; }
        document.getElementById("opLoading").checked = true;
        document.getElementById("modeS").checked = true;
        onLoadModeChange(); onOpTypeChange();
    }

    /* ═══ DROPDOWN DATA LOADING ═══ */
    function loadDropdownData() {
        fetch("/TruckRegistration/GetOilCompanies")
            .then(function (r) { return r.json(); })
            .then(function (d) { oilCompList = d || []; fillDd("oilCompanyDropdown", oilCompList, "oilCompanySelect", "oilCompanyLabel", null); });

        fetch("/TruckRegistration/GetPlantCodes")
            .then(function (r) { return r.json(); })
            .then(function (d) { plantList = d || []; fillDd("plantDropdown", plantList, "plantSelect", "plantLabel", "plantDesc"); });

        fetch("/TruckRegistration/GetTransporterCodes")
            .then(function (r) { return r.json(); })
            .then(function (d) {
                transporterList = d || [];
                fillDd("transporterDropdown",  transporterList, "transporterSelect",  "transporterLabel",  "transporterDesc");
                fillDd("mTransporterDropdown", transporterList, "mTransporterSelect", "mTransporterLabel", "mTransporterDesc");
            });

        fetch("/TruckRegistration/GetDestinationCodes")
            .then(function (r) { return r.json(); })
            .then(function (d) {
                destinationList = d || [];
                fillDd("destinationDropdown",  destinationList, "destinationSelect",  "destinationLabel",  "destinationDesc");
                fillDd("mDestinationDropdown", destinationList, "mDestinationSelect", "mDestinationLabel", "mDestinationDesc");
            });

        fetch("/TruckRegistration/GetLocationCodes")
            .then(function (r) { return r.json(); })
            .then(function (d) {
                locationList = d || [];
                fillDd("locationDropdown",  locationList, "locationSelect",  "locationLabel",  "locationDesc");
                fillDd("mLocationDropdown", locationList, "mLocationSelect", "mLocationLabel", "mLocationDesc");
            });

        fetch("/TruckRegistration/GetCustomerCodes")
            .then(function (r) { return r.json(); })
            .then(function (d) {
                customerList = d || [];
                fillDd("customerDropdown", customerList, "customerSelect", "customerLabel", "customerDesc");
                fillDd("mCustomerDropdown", customerList, "mCustomerSelect", "mCustomerLabel", "mCustomerDesc");
            });

        fetch("/TruckRegistration/GetProducts")
            .then(function (r) { return r.json(); })
            .then(function (d) { productsList = d || []; });
    }

    function fillDd(ddId, list, selId, labelId, descFieldId) {
        var dd = document.getElementById(ddId);
        if (!dd) return;
        if (!list.length) { dd.innerHTML = '<div class="option" data-disabled="1">None available</div>'; return; }
        dd.innerHTML = list.map(function (item) {
            var display = item.code + (item.desc ? " \u2014 " + item.desc : "");
            return '<div class="option" data-val="' + escAttr(item.code) + '" data-desc="' + escAttr(item.desc || "") + '">' + esc(display) + '</div>';
        }).join("");
    }

    function loadRegReasons(cb) {
        fetch("/TruckRegistration/GetRegistrationReasons")
            .then(function (r) { return r.json(); })
            .then(function (d) { regReasonList = d || []; if (cb) cb(); });
    }

    function renderRegReasons() {
        var dd = document.getElementById("regReasonDropdown");
        if (!regReasonList.length) { dd.innerHTML = '<div class="option" data-disabled="1">No reasons defined</div>'; return; }
        dd.innerHTML = regReasonList.map(function (r) {
            return '<div class="option" data-val="' + escAttr(r.reasonDescription) + '" onclick="selectRegReason(\'' + escJs(r.reasonDescription) + '\')">' + esc(r.reasonDescription) + '</div>';
        }).join("");
    }

    /* ═══ DROPDOWN WIRING — delegation pattern (same as attendance page) ═══ */
    function wireDropdowns() {
        // Registration reason modal dropdown, scoped like attendance page.
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".rg-dd, .te-modal-select, .rg-prod-dd")) {
                document.querySelectorAll(".rg-dd.open, .te-modal-select.open, .rg-prod-dd.open").forEach(function (s) {
                    s.classList.remove("open");
                    s.classList.remove("drop-up");
                });
            }
        });

        // Option mousedown — select value
        document.addEventListener("mousedown", function (e) {
            // rg-dd option
            var rgOpt = e.target.closest(".rg-dd .option");
            if (rgOpt) {
                if (rgOpt.closest(".te-modal-select")) return;
                e.preventDefault(); e.stopPropagation();
                if (rgOpt.getAttribute("data-disabled")) return;
                var selEl = rgOpt.closest(".rg-dd");
                if (!selEl) return;
                var val  = rgOpt.getAttribute("data-val");
                var desc = rgOpt.getAttribute("data-desc") || "";
                var selId   = selEl.id;
                var labelEl = document.getElementById(selId + "Label");
                // fallback label pattern
                if (!labelEl) {
                    var lbl = selEl.querySelector(".rg-dd-trigger span:first-child");
                    if (lbl) lbl.textContent = val;
                } else {
                    labelEl.textContent = val;
                }
                selEl.setAttribute("data-val", val);
                selEl.classList.remove("open");
                // Fill desc
                var descMap = {
                    "transporterSelect":  "transporterDesc",
                    "plantSelect":        "plantDesc",
                    "mTransporterSelect": "mTransporterDesc",
                    "destinationSelect":  "destinationDesc",
                    "mDestinationSelect": "mDestinationDesc",
                    "locationSelect":     "locationDesc",
                    "mLocationSelect":    "mLocationDesc",
                    "customerSelect":     "customerDesc",
                    "mCustomerSelect":    "mCustomerDesc"
                };
                if (descMap[selId]) { var fi = document.getElementById(descMap[selId]); if (fi) fi.value = desc; }
                if (selId === "mTransporterSelect" || selId === "mDestinationSelect" || selId === "mLocationSelect" || selId === "mCustomerSelect") {
                    renderLoadingTable();
                }
                return;
            }

            var modalOpt = e.target.closest("#regReasonDropdown .option");
            if (modalOpt) {
                e.preventDefault(); e.stopPropagation();
                if (modalOpt.getAttribute("data-disabled")) return;
                var val2 = modalOpt.getAttribute("data-val");
                document.getElementById("regReasonLabel").textContent = val2;
                document.getElementById("regReasonSelect").setAttribute("data-val", val2);
                document.getElementById("regReasonSelect").classList.remove("open");
            }
        });
    }

    function toggleDd(selId) {
        var el = document.getElementById(selId);
        if (!el) return;
        var wasOpen = el.classList.contains("open");
        document.querySelectorAll(".rg-dd.open").forEach(function (s) { s.classList.remove("open"); });
        if (!wasOpen) el.classList.add("open");
    }

    /* ═══ MODAL HELPERS ═══ */
    function rgOpen(modalId, backdropId) {
        var m = document.getElementById(modalId);
        var b = backdropId ? document.getElementById(backdropId) : null;
        if (!m) return;
        m.style.display = "block";
        if (b) b.style.display = "block";
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                m.classList.add("show");
                if (b) b.classList.add("show");
            });
        });
    }

    function rgClose(modalId, backdropId) {
        var m = document.getElementById(modalId);
        var b = backdropId ? document.getElementById(backdropId) : null;
        if (!m) return;
        m.classList.remove("show");
        if (b) b.classList.remove("show");
        setTimeout(function () {
            m.style.display = "none";
            if (b) b.style.display = "none";
        }, 220);
    }

    function rgShowMsg(txt) {
        document.getElementById("rgErrText").textContent = txt;
        rgOpen("rgErrModal", "rgErrBackdrop");
    }

    /* ═══ FORMATTERS ═══ */
    function fmtDec(v) { return v == null ? "<span style='color:rgba(255,255,255,0.18)'>&mdash;</span>" : parseFloat(v).toFixed(2); }
    function fmtDate(v) {
        if (!v) return "<span style='color:rgba(255,255,255,0.18)'>&mdash;</span>";
        var d = new Date(v); if (isNaN(d)) return esc(v);
        return ("0" + d.getDate()).slice(-2) + "/" + ("0" + (d.getMonth() + 1)).slice(-2) + "/" + d.getFullYear();
    }
    function licClass(v) {
        if (!v) return "";
        var diff = (new Date(v) - new Date()) / 86400000;
        if (diff < 0) return "te-lic-exp"; if (diff < 30) return "te-lic-warn"; return "te-lic-ok";
    }
    function setEmpty(id, msg, show) { var el = document.getElementById(id); if (el) { el.textContent = msg; el.style.display = show ? "block" : "none"; } }
    function esc(s)     { if (s == null) return ""; return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
    function escJs(s)   { if (s == null) return ""; return String(s).replace(/\\/g,"\\\\").replace(/'/g,"\\'"); }
    function escVal(v)  { if (v == null || v === "") return "&mdash;"; return esc(String(v)); }
    function escAttr(s) { if (s == null) return ""; return String(s).replace(/&/g,"&amp;").replace(/"/g,"&quot;").replace(/'/g,"&#39;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
    function fmtD(v)    { return fmtDec(v); }
    function fmtDt(v)   { return fmtDate(v); }
</script>
