            min-width: max-content;
        }

    .rg-loading-table .table-header,
    .rg-loading-table .table-body {
        min-width: unset;
        width: 100%;
    }

    .table-header {
        display: grid;
        align-items: center;
        width: max-content;
        position: relative;
        z-index: 2;
    }

    .table-body {
        display: block;
        width: max-content;
        overflow-y: auto;
        overflow-x: hidden;
        flex: 1;
        min-height: 0;
        position: relative;
        z-index: 1;
    }

    .bay-table .table-header, .bay-table .table-row {
        display: grid;
        align-items: center;
    }

    /* ── Radio ── */
    .te-row-check {
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

        .te-row-check input[type="radio"] {
            display: none;
        }

    .te-radio-mark {
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 1.4px solid rgba(255,255,255,0.28);
        background: rgba(255,255,255,0.03);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.18s ease;
        position: relative;
        pointer-events: none;
    }

    .te-row-check input:checked + .te-radio-mark {
        background: linear-gradient(180deg,#ff4d4d 0%,#cc0000 100%);
        border-color: #e10600;
        box-shadow: 0 0 4px rgba(225,6,0,0.45);
    }

    .te-radio-mark::after {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fff;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.18s ease;
    }

    .te-row-check input:checked + .te-radio-mark::after {
        opacity: 1;
        transform: scale(1);
    }

    .te-radio-mark:hover {
        border-color: rgba(255,255,255,0.45);
        background: rgba(255,255,255,0.04);
    }

    /* ── Status badges ── */
    .te-status-y {
        color: #00ff9c;
        font-size: 12px;
        font-weight: 600;
        text-shadow: 0 0 5px rgba(0,255,150,0.4);
